---
// @Isanchezv
// src/components/BaseHead.astro

import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { languages } from '@/i18n/ui';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  articleDate?: string;
  iconLight?: string;
  iconDark?: string;
  keywords?: string;
  noindex?: boolean;
}

const {
  title,
  image = '/og-image.png',
  canonicalURL = Astro.url.href,
  articleDate,
  iconLight = '/Black.svg',
  iconDark = '/White.svg',
  keywords = 'FTC robotics, FIRST Tech Challenge, robotics team, STEM robotics, robotics competition, BRAIN BOX FTC',
  noindex = false
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const description = Astro.props.description || t('site.description');

const siteName = "BRAIN BOX FTC";
const siteUrl = "https://brain-box-ftc.vercel.app";

const siteTitle = `${title} | ${siteName}`;

const ogLocales: Record<string, string> = {
  es: "es_MX",
  en: "en_US"
};

const currentOgLocale = ogLocales[lang] || "es_MX";

const { pathname } = Astro.url;

const getPathForLang = (l: string) => {
  const parts = pathname.split('/');
  parts[1] = l;
  return new URL(parts.join('/') || `/${l}`, Astro.url);
};

const ogImage = new URL(image, Astro.url);

const schemaWebsite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteName,
  "url": siteUrl,
  "inLanguage": lang,
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${siteUrl}/search?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const schemaOrganization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": siteName,
  "url": siteUrl,
  "logo": `${siteUrl}/logo.png`,
  "sameAs": [
    "https://github.com/",
    "https://instagram.com/"
  ]
};

const schemaPage = {
  "@context": "https://schema.org",
  "@type": articleDate ? "Article" : "WebPage",
  "headline": title,
  "description": description,
  "url": canonicalURL,
  "datePublished": articleDate,
  "inLanguage": lang,
  "isPartOf": {
    "@type": "WebSite",
    "name": siteName,
    "url": siteUrl
  }
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<meta name="generator" content={Astro.generator} />
<meta name="author" content={siteName} />

<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
<meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)">

<meta name="keywords" content={keywords} />

<meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"} />

<meta name="google-site-verification" content="R5oODU1CIVba_m7OK8l04dj1D35e2By2W7pAP4iHU8M" />

<link rel="canonical" href={canonicalURL} />

<!-- Performance -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="sitemap" href="/sitemap-index.xml">
<link rel="dns-prefetch" href="//vercel.app">

<!-- Icons -->
<link rel="icon" type="image/svg+xml" href={iconLight}>
<link rel="icon" type="image/svg+xml" href={iconLight} media="(prefers-color-scheme: light)">
<link rel="icon" type="image/svg+xml" href={iconDark} media="(prefers-color-scheme: dark)">
<link rel="apple-touch-icon" href={iconLight}>

<!-- Language alternates -->
{Object.keys(languages).map((l) => (
  <link rel="alternate" hreflang={l} href={getPathForLang(l)} />
))}
<link rel="alternate" hreflang="x-default" href={getPathForLang('es')} />

<link rel="sitemap" href="/sitemap-index.xml" />

<title>{siteTitle}</title>

<meta name="title" content={siteTitle} />
<meta name="description" content={description} />

<!-- Open Graph -->
<meta property="og:type" content={articleDate ? "article" : "website"} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content={currentOgLocale} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={siteTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={siteTitle} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

{Object.keys(ogLocales).map((l) => (
  <meta property="og:locale:alternate" content={ogLocales[l]} />
))}

{articleDate && (
  <meta property="article:published_time" content={articleDate} />
)}

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(schemaWebsite)} />
<script type="application/ld+json" set:html={JSON.stringify(schemaOrganization)} />
<script type="application/ld+json" set:html={JSON.stringify(schemaPage)} />