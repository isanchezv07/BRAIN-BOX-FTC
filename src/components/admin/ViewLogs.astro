---
// @Isanchezv
// src/components/admin/ViewLogs.astro
import { useTranslations, getLangFromUrl } from "@/i18n/utils";

interface Props {
  auditData: any[];
  isAdmin: boolean;
}

const { auditData, isAdmin } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="bg-black border border-white/5 rounded-[2.5rem] p-8 shadow-2xl relative overflow-hidden group">
  <div class="absolute -top-24 -right-24 w-48 h-48 bg-blue-600/5 blur-[100px] rounded-full"></div>

  <div class="flex justify-between items-center mb-8 relative z-10">
    <div class="flex items-center gap-3">
      <div class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></div>
      <h4 class="text-[10px] font-black text-blue-500 uppercase tracking-[0.2em] italic">
        {t('admin.logs.title')}
      </h4>
    </div>
    
    {isAdmin && (
      <button 
        class="text-[9px] font-black text-red-500/40 hover:text-red-500 hover:bg-red-500/10 px-3 py-1 rounded-full border border-red-500/10 transition-all uppercase tracking-tighter"
      >
        {t('admin.logs.purge')}
      </button>
    )}
  </div>

  <div class="space-y-6 max-h-[500px] overflow-y-auto pr-2 custom-scrollbar relative z-10">
    {auditData && auditData.length > 0 ? (
      auditData.map((log) => (
        <div class="relative pl-6 border-l border-white/5 hover:border-blue-500/30 transition-colors group/item">
          <div class="flex justify-between text-[9px] font-mono mb-2">
            <div class="flex gap-2">
                <span class="text-blue-400 font-black uppercase">[{log.action_type}]</span>
                <span class="text-gray-600">ID: {log.id.split('-')[0]}</span>
            </div>
            <span class="text-gray-500">
              {new Date(log.created_at).toLocaleTimeString(lang)}
            </span>
          </div>
          
          <div class="space-y-1">
            <p class="text-[11px] text-gray-400 font-medium leading-relaxed tracking-tight">
              <span class="text-gray-600 uppercase text-[9px] font-black">
                {t('admin.logs.target')}
              </span> 
              <span class="text-white"> @{log.profiles?.username || t('admin.logs.system')}</span>
            </p>
            
            {log.mod?.username && (
              <p class="text-[11px] text-gray-400 font-medium leading-relaxed tracking-tight">
                <span class="text-blue-900 uppercase text-[9px] font-black">
                  {t('admin.logs.executedBy')}
                </span> 
                <span class="text-blue-400/80 italic"> @{log.mod.username}</span>
              </p>
            )}

            <p class="text-[10px] text-gray-500 italic mt-2 bg-white/[0.02] p-2 rounded-lg border border-white/5">
              {log.details}
            </p>
          </div>
        </div>
      ))
    ) : (
      <div class="py-20 text-center">
        <p class="text-[10px] font-black text-gray-600 uppercase tracking-widest">
          {t('admin.logs.noLogs')}
        </p>
      </div>
    )}
  </div>
</div>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(37, 99, 235, 0.2);
  }
</style>