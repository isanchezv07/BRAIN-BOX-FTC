---
// @Isanchezv
// src/components/admin/UserManagement.astro
import { useTranslations } from "@/i18n/utils";

const { profiles, lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="space-y-6">
  <div class="flex items-center justify-between px-2">
    <div>
      <h3 class="text-xl font-black italic uppercase tracking-tighter text-white">
        {t('admin.users.title')}
      </h3>
      <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mt-1">
        {t('admin.users.subtitle')}
      </p>
    </div>
    <span class="bg-blue-500/10 text-blue-500 text-[10px] font-bold px-4 py-2 rounded-xl border border-blue-500/20 uppercase tracking-widest">
      {profiles?.length || 0} {t('admin.users.count')}
    </span>
  </div>

  <div class="bg-[#0a0a0a] border border-white/5 rounded-2xl shadow-2xl overflow-x-auto">
    <table class="w-full text-left border-collapse min-w-[800px]">
      <thead class="bg-white/[0.03] border-b border-white/5">
        <tr>
          <th class="px-6 py-5 text-[10px] font-black uppercase text-gray-500 tracking-widest">{t('admin.users.table.name')}</th>
          <th class="px-6 py-5 text-[10px] font-black uppercase text-gray-500 tracking-widest text-center">{t('admin.users.table.status')}</th>
          <th class="px-6 py-5 text-[10px] font-black uppercase text-gray-500 tracking-widest text-center">{t('admin.users.table.role')}</th>
          <th class="px-6 py-5 text-[10px] font-black uppercase text-gray-500 tracking-widest">{t('admin.users.table.country')}</th>
          <th class="px-6 py-5 text-[10px] font-black uppercase text-gray-500 tracking-widest text-right">{t('admin.users.table.action')}</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-white/5">
        {profiles?.map((u) => (
          <tr 
            class="hover:bg-white/[0.03] transition-all group cursor-pointer" 
            onclick={`openUserModal(${JSON.stringify(u)})`}
          >
            <td class="px-6 py-4">
              <div class="flex items-center gap-4">
                <div class="w-11 h-11 shrink-0 rounded-xl bg-gradient-to-br from-blue-600/20 to-purple-600/20 flex items-center justify-center border border-white/10 font-black text-blue-500 shadow-lg group-hover:scale-105 transition-transform overflow-hidden">
                  {u.avatar_url ? (
                    <img src={u.avatar_url} class="w-full h-full object-cover" alt="" />
                  ) : (
                    u.full_name?.charAt(0).toUpperCase() || 'U'
                  )}
                </div>
                <div>
                  <p class="text-sm font-black text-white italic leading-none mb-1">{u.full_name || 'Sin Nombre'}</p>
                  <p class="text-[10px] text-gray-500 uppercase font-bold tracking-widest">@{u.username || 'user'}</p>
                </div>
              </div>
            </td>

            <td class="px-6 py-4 text-center">
              <span class={`text-[8px] font-black uppercase px-2 py-0.5 rounded border ${
                u.status === 'perma-ban' ? 'bg-red-500/10 text-red-500 border-red-500/20' : 
                u.status === 'temporal-ban' ? 'bg-orange-500/10 text-orange-500 border-orange-500/20' : 
                'bg-green-500/10 text-green-400 border-green-500/20'
              }`}>
                {u.status || 'active'}
              </span>
            </td>
            
            <td class="px-6 py-4 text-center">
              <span class={`text-[9px] font-black uppercase px-3 py-1 rounded-full border shadow-sm ${
                u.role === 'admin'   ? 'bg-purple-500/10 text-purple-400 border-purple-500/20' : 
                u.role === 'teacher' ? 'bg-amber-500/10 text-amber-500 border-amber-500/20' : 
                u.role === 'mod'     ? 'bg-blue-500/10 text-blue-400 border-blue-500/20' :
                'bg-gray-500/10 text-gray-400 border-gray-500/20' 
              }`}>
                {u.role}
              </span>
            </td>

            <td class="px-6 py-4">
              <p class="text-xs font-black text-gray-400 leading-none mb-1 tracking-tighter uppercase italic">
                {u.country || 'Global'}
              </p>
              <div class="flex gap-1">
                {u.first_categories?.map((cat: string) => (
                   <span class={`text-[7px] font-black px-1.5 py-0.5 rounded ${cat === 'FTC' ? 'bg-orange-500/20 text-orange-500' : cat === 'FRC' ? 'bg-blue-500/20 text-blue-500' : 'bg-red-500/20 text-red-500'}`}>
                     {cat}
                   </span>
                ))}
              </div>
            </td>

            <td class="px-6 py-4 text-right" onclick="event.stopPropagation()">
              <form method="POST" class="inline-block">
                <input type="hidden" name="id" value={u.id} />
                <input type="hidden" name="_action" value="update-profile-role" />
                <select 
                  name="role" 
                  onchange="this.form.submit()" 
                  class="bg-[#0d0d0d] border border-white/10 text-[10px] font-black uppercase px-3 py-1.5 rounded-lg hover:border-blue-500/50 transition-all outline-none cursor-pointer text-gray-300"
                >
                  <option value="student" selected={u.role === 'student'}>{t('admin.users.roles.student')}</option>
                  <option value="mod" selected={u.role === 'mod'}>{t('admin.users.roles.mod')}</option>
                  <option value="teacher" selected={u.role === 'teacher'}>{t('admin.users.roles.teacher')}</option>
                </select>
              </form>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<div id="user-modal" 
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4"
  data-no-bio={t('admin.users.modal.noBio')}
  data-lang={lang}
>
  <div id="modal-overlay" class="absolute inset-0 bg-black/80 backdrop-blur-md" onclick="closeUserModal()"></div>
  <div class="relative bg-[#0d0d0d] border border-white/10 w-full max-w-2xl rounded-[2.5rem] overflow-hidden shadow-2xl animate-in zoom-in duration-300">
    
    <div class="h-32 bg-gradient-to-r from-blue-600 to-purple-600 relative">
        <button onclick="closeUserModal()" class="absolute top-6 right-6 w-10 h-10 bg-black/20 hover:bg-black/40 backdrop-blur-md rounded-full text-white transition-all z-10">✕</button>
    </div>
    
    <div class="px-8 pb-10">
        <div class="flex flex-col md:flex-row gap-6 -mt-16 items-center md:items-end mb-8 px-4 relative z-20">
            <div id="modal-avatar" class="w-32 h-32 shrink-0 rounded-[2.5rem] bg-[#0a0a0a] border-4 border-[#0d0d0d] flex items-center justify-center text-4xl font-black text-blue-500 overflow-hidden shadow-2xl"></div>
            <div class="flex-1 pb-2 text-center md:text-left">
                <h4 id="modal-name" class="text-2xl font-black italic uppercase tracking-tighter text-white"></h4>
                <div class="flex items-center justify-center md:justify-start gap-2">
                    <p id="modal-username" class="text-sm font-bold text-blue-500 uppercase tracking-widest"></p>
                    <div id="modal-status-badge"></div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-6">
                <div>
                    <p class="text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] mb-2 italic">{t('admin.users.modal.bio')}</p>
                    <p id="modal-bio" class="text-xs text-gray-400 leading-relaxed font-medium italic"></p>
                </div>

                <div class="">
                  <div>
                      <p class="text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] mb-2 italic">{t('admin.users.modal.programs')}</p>
                      <div id="modal-categories" class="flex flex-wrap gap-1.5"></div>
                  </div>
                  <div>
                      <p class="text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] mt-6 italic">Idiomas</p>
                      <div id="modal-languages" class="flex flex-wrap gap-1.5"></div>
                  </div>
                </div>

                <div class="pt-4 border-t border-white/5">
                    <p class="text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] mb-2 italic">{t('admin.users.modal.email')}</p>
                    <p id="modal-email" class="text-xs font-mono text-blue-400 underline"></p>
                </div>
            </div>

            <div class="bg-red-500/5 border border-red-500/10 rounded-3xl p-6 flex flex-col justify-between">
                <div>
                    <p class="text-[10px] font-black text-red-500 uppercase tracking-widest mb-4 italic underline decoration-red-500/30 underline-offset-4">
                      {t('admin.users.modal.security')}
                    </p>
                    
                    <form method="POST" class="space-y-4">
                        <input type="hidden" name="id" id="modal-input-id" />
                        <input type="hidden" name="_action" value="update-user-status" />
                        
                        <div class="space-y-2">
                            <label class="text-[9px] font-black text-gray-600 uppercase tracking-tighter italic">{t('admin.users.modal.statusLevel')}</label>
                            <select name="status" id="modal-select-status" class="w-full bg-black border border-white/10 rounded-xl px-3 py-2 text-xs font-bold outline-none focus:border-red-500/50 transition-all text-white italic">
                                <option value="active">🟢 ACTIVE</option>
                                <option value="temporal-ban">🟠 TEMPORAL-BAN</option>
                                <option value="perma-ban">🔴 PERMA-BAN</option>
                            </select>
                        </div>

                        <div id="ban-expiry-container" class="space-y-2 hidden">
                            <label class="text-[9px] font-black text-orange-500 uppercase tracking-tighter italic">{t('admin.users.modal.banDuration')}</label>
                            <div class="relative">
                                <input type="number" name="ban_duration_custom" id="modal-input-duration" class="w-full bg-black border border-white/10 rounded-xl px-3 py-2 text-xs font-bold outline-none text-white focus:border-orange-500/50" />
                            </div>
                            <p class="text-[7px] text-gray-500 font-mono italic">{t('admin.users.modal.banHint')}</p>
                        </div>

                        <button type="submit" class="w-full bg-red-600 hover:bg-red-500 text-white text-[10px] font-black uppercase py-4 rounded-xl transition-all mt-4 italic tracking-widest">
                            {t('admin.users.modal.execute')}
                        </button>
                    </form>
                </div>

                <div class="mt-4 pt-4 border-t border-red-500/10 text-[8px] text-gray-600 font-mono uppercase">
                    <p>SYSTEM_ID: <span id="modal-footer-id"></span></p>
                    <p class="mt-1">{t('admin.users.modal.joinDate')}: <span id="modal-date" class="text-gray-500 font-bold"></span></p>
                </div>
            </div>
        </div>
    </div>
  </div>
</div>

<script is:inline>
function openUserModal(u) {
  const modal = document.getElementById('user-modal');
  const noBioTxt = modal.dataset.noBio;
  const lang = modal.dataset.lang;

  document.getElementById('modal-input-id').value = u.id;
  document.getElementById('modal-footer-id').innerText = u.id;
  document.getElementById('modal-name').innerText = u.full_name || 'Anonymous User';
  document.getElementById('modal-username').innerText = `@${u.username || 'user'}`;
  document.getElementById('modal-email').innerText = u.email || 'N/A';
  document.getElementById('modal-bio').innerText = u.bio || noBioTxt;
  document.getElementById('modal-date').innerText = new Date(u.created_at).toLocaleDateString(lang);

  const catContainer = document.getElementById('modal-categories');
  catContainer.innerHTML = '';
  if (u.first_categories && u.first_categories.length > 0) {
    u.first_categories.forEach(cat => {
      const span = document.createElement('span');
      const colorClass = cat === 'FTC' ? 'bg-orange-500/20 text-orange-500' : 
                         cat === 'FRC' ? 'bg-blue-500/20 text-blue-500' : 
                         'bg-red-500/20 text-red-500';
      span.className = `text-[7px] font-black px-2 py-0.5 rounded border border-white/5 ${colorClass}`;
      span.innerText = cat;
      catContainer.appendChild(span);
    });
  } else {
    catContainer.innerHTML = '<span class="text-[8px] text-gray-600 italic">N/A</span>';
  }

  const langContainer = document.getElementById('modal-languages');
  langContainer.innerHTML = '';
  if (u.languages && u.languages.length > 0) {
    u.languages.forEach(l => {
      const span = document.createElement('span');
      span.className = 'bg-white/5 border border-white/10 text-gray-400 text-[7px] font-black px-2 py-0.5 rounded uppercase italic';
      span.innerText = l;
      langContainer.appendChild(span);
    });
  } else {
    langContainer.innerHTML = '<span class="text-[8px] text-gray-600 italic">N/A</span>';
  }

  const selectStatus = document.getElementById('modal-select-status');
  const expiryContainer = document.getElementById('ban-expiry-container');
  const durationInput = document.getElementById('modal-input-duration');

  selectStatus.value = u.status || 'active';
  expiryContainer.style.display = (u.status === 'temporal-ban') ? 'block' : 'none';

  selectStatus.onchange = () => {
    expiryContainer.style.display = (selectStatus.value === 'temporal-ban') ? 'block' : 'none';
  };

  const avatarDiv = document.getElementById('modal-avatar');
  avatarDiv.innerHTML = u.avatar_url 
    ? `<img src="${u.avatar_url}" class="w-full h-full object-cover" />`
    : `<span class="italic">${(u.full_name || 'U').charAt(0).toUpperCase()}</span>`;

  modal.classList.remove('hidden');
  modal.classList.add('flex');
  document.body.style.overflow = 'hidden';
}

function closeUserModal() {
  const modal = document.getElementById('user-modal');
  modal.classList.add('hidden');
  modal.classList.remove('flex');
  document.body.style.overflow = 'auto';
}
</script>