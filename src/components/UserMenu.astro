---
// @Isanchezv
// src/components/UserMenu.astro
import { supabase } from "@/lib/supabase";
import { useTranslations } from "@/i18n/utils";
import LanguagePicker from "./LanguagePicker.astro";
const { pathname } = Astro.url;

const currentLang = pathname.split("/")[1] || "es";

const langLabel = {
  es: "Español",
  en: "English",
};

const { profile, lang, email } = Astro.props;
const t = useTranslations(lang);

const getInitials = (name: string | null | undefined) => {
  if (!name || typeof name !== 'string') return "??";
  const parts = name.trim().split(/\s+/);
  return (parts[0][0] + (parts.length > 1 ? parts[parts.length - 1][0] : '')).toUpperCase();
};

const initials = getInitials(profile?.full_name);
const displayName = profile?.full_name?.trim() || t('userMenu.defaultName');

const roleConfig = {
    admin: {
        name: 'ADMINISTRADOR',
        style: 'bg-purple-500/10 text-purple-400 border-purple-500/20',
        iconColor: 'bg-purple-500/20 text-purple-400'
    },
    teacher: {
        name: 'TEACHER / MENTOR',
        style: 'bg-amber-500/10 text-amber-500 border-amber-500/20',
        iconColor: 'bg-amber-500/20 text-amber-500'
    },
    mod: {
        name: 'MODERADOR',
        style: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
        iconColor: 'bg-blue-500/20 text-blue-400'
    },
    student: {
        name: 'ESTUDIANTE',
        style: 'bg-gray-500/10 text-gray-400 border-gray-500/20',
        iconColor: 'bg-gray-500/20 text-gray-400'
    }
};

const currentRole = profile?.role as keyof typeof roleConfig || 'student';
const badgeClass = roleConfig[currentRole].style;
const displayRole = roleConfig[currentRole].name;

let totalPublishedCourses = 0;
let completedCoursesCount = 0;

if (profile?.id) {
  const { data: userProgress } = await supabase.from("lesson_progress").select("lesson_id").eq("user_id", profile.id).eq("completed", true);
  const completedLessonIds = new Set(userProgress?.map(p => p.lesson_id) || []);
  const { data: courses } = await supabase.from("courses").select("id, lessons(id)").eq("is_published", true);

  if (courses) {
    totalPublishedCourses = courses.length;
    completedCoursesCount = courses.filter(course => {
      const lessons = course.lessons || [];
      return lessons.length > 0 && lessons.every(l => completedLessonIds.has(l.id));
    }).length;
  }
}

const isStaff = ['admin' , 'mod'].includes(currentRole);
---

<div class="relative" x-data="{ open: false }">
  <button
    @click="open = !open"
    @keydown.escape.window="open = false" 
    type="button"
    class="flex items-center gap-3 p-1 pr-3 rounded-full border border-white/5 bg-white/[0.03] hover:bg-white/[0.08] transition-all group"
    :class="open ? 'ring-2 ring-blue-500/50 bg-white/[0.08]' : ''"
  >
    <div class="relative w-8 h-8 rounded-full bg-gradient-to-tr from-blue-600 to-indigo-600 p-[1px] shadow-lg shadow-blue-500/20 transition-all">
      <div class="w-full h-full rounded-full bg-[#050505] flex items-center justify-center overflow-hidden">
        {profile?.avatar_url ? (
          <img src={profile.avatar_url} alt={displayName} class="w-full h-full object-cover" />
        ) : (
          <span class="text-[10px] font-black text-white italic">{initials}</span>
        )}
      </div>
    </div>
    <div class="hidden sm:flex flex-col items-start leading-none text-left">
      <span class="text-[11px] font-black text-white uppercase italic tracking-tighter">{displayName}</span>
      <span class="text-[9px] font-bold text-gray-500 uppercase tracking-widest mt-0.5 group-hover:text-blue-400 transition-colors">{displayRole}</span>
    </div>
    <svg class="h-4 w-4 text-gray-600 transition-transform" :class="open ? 'rotate-180 text-blue-500' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div
    x-show="open"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 scale-95 -translate-y-2"
    x-transition:enter-end="opacity-100 scale-100 translate-y-0"
    @click.outside="open = false"
    class="absolute right-0 mt-3 w-72 rounded-3xl border border-white/10 bg-[#0a0a0a]/95 backdrop-blur-2xl shadow-2xl overflow-hidden z-[110]"
  >
    <div class="px-6 py-5 border-b border-white/5 bg-white/[0.02] relative">
      <p class="text-[13px] font-black text-white uppercase italic tracking-tighter truncate">{displayName}</p>
      <p class="text-[10px] text-gray-500 truncate font-mono mt-0.5 mb-3">{email}</p>
      <span class={`text-[9px] font-black px-2.5 py-1 rounded-lg uppercase tracking-tighter inline-block border ${badgeClass}`}>
        {currentRole}
      </span>
    </div>

    <div class="grid grid-cols-2 gap-px bg-white/5 border-b border-white/5">
      <div class="bg-[#0a0a0a] px-5 py-4 flex flex-col items-center">
        <span class="text-white font-black italic text-lg leading-none">
          {totalPublishedCourses}
        </span>
        <span class="text-[8px] text-gray-500 uppercase font-bold tracking-widest mt-1">
          {t('userMenu.stats.courses')}
        </span>
      </div>
    
      <div class="bg-[#0a0a0a] px-5 py-4 flex flex-col items-center">
        <span class="text-white font-black italic text-lg leading-none">
          {completedCoursesCount}
        </span>
        <span class="text-[8px] text-gray-500 uppercase font-bold tracking-widest mt-1">
          {t('userMenu.stats.completed')}
        </span>
      </div>
    
      <div
        class="bg-[#0a0a0a] col-span-2 px-5 py-4
              flex justify-center items-center
              relative
              border-t border-white/5
              hover:bg-[#0f0f0f] transition-colors"
      >
        <div class="flex items-center gap-4">
          <span
            class="text-[10px] uppercase tracking-widest
                  text-gray-500 font-bold"
          >
            {t('userMenu.links.language')}
          </span>

          <span
            class="text-xs font-bold text-white/80
                  px-2 py-0.5 rounded-full
                  bg-white/5 border border-white/10"
          >
            {langLabel[currentLang] ?? currentLang.toUpperCase()}
          </span>

          <div
            class="px-3 py-1.5 rounded-full
                  bg-[#111]
                  border border-white/10
                  shadow-inner"
          >
            <LanguagePicker />
          </div>
        </div>
      </div>
    </div>

    <nav class="p-3 flex flex-col gap-1">
      
      <a href={`/${lang}/perfil`} class="flex items-center gap-3 px-4 py-3 text-[11px] font-bold text-gray-400 hover:text-white hover:bg-white/5 rounded-2xl transition-all uppercase tracking-widest group">
        <span class="p-2 rounded-xl bg-gray-900 group-hover:bg-blue-500/20 transition-all shadow-inner">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
        </span>
        {t('userMenu.links.settings') || 'Mi Perfil'}
      </a>

      <a href={`/${lang}/explore`} class="flex items-center gap-3 px-4 py-3 text-[11px] font-bold text-gray-400 hover:text-white hover:bg-white/5 rounded-2xl transition-all uppercase tracking-widest group">
        <span class="p-2 rounded-xl bg-gray-900 group-hover:bg-green-500/20 transition-all shadow-inner">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
        </span>
        {t('userMenu.links.lessons')}
      </a>

      <a href={`/${lang}/dashboard`} class="flex items-center gap-3 px-4 py-3 text-[11px] font-bold text-gray-400 hover:text-white hover:bg-white/5 rounded-2xl transition-all uppercase tracking-widest group">
        <span class="p-2 rounded-xl bg-gray-900 group-hover:bg-blue-500/20 transition-all shadow-inner">
          <svg 
            class="w-4 h-4 transition-colors duration-300 group-hover:text-blue-500" 
            viewBox="0 0 24 24" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="2.5" 
            stroke-linecap="round" 
            stroke-linejoin="round"
          >
            <rect x="3" y="3" width="7" height="7"></rect>
            <rect x="14" y="3" width="7" height="7"></rect>
            <rect x="14" y="14" width="7" height="7"></rect>
            <rect x="3" y="14" width="7" height="7"></rect>
          </svg>
        </span>
        {t('userMenu.links.dashboard')}
      </a>

      {(currentRole === "student" || isStaff) && (
        <a href={`/${lang}/playground`} class="flex items-center gap-3 px-4 py-3 text-[11px] font-bold text-cyan-400 hover:text-cyan-400 hover:bg-white/5 rounded-2xl transition-all uppercase tracking-widest group">
          <span class="p-2 rounded-xl bg-gray-900 group-hover:bg-blue-500/20 group-hover:text-blue-400 transition-all shadow-inner border border-white/5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 20h16" />
                  <path d="M6 20v-2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" />
                  <circle cx="12" cy="16" r="1" />
                  <path d="M12 16V9" />
                  <circle cx="12" cy="9" r="1" />
                  <path d="M12 9l4-4" />
                  <path d="M16 5l-2-2" />
                  <path d="M16 5l2 2" />
              </svg>
          </span>
          {t('userMenu.links.playground')}
        </a>
      )}

      {(currentRole === "teacher" || isStaff) && (
        <a href={`/${lang}/teacher/portfolio-ai`} class="flex items-center gap-3 px-4 py-3 text-[11px] font-bold text-amber-500 hover:bg-amber-500/5 rounded-2xl transition-all uppercase tracking-widest group">
          <span class="p-2 rounded-xl bg-amber-500/10 group-hover:bg-amber-500/20 transition-all shadow-inner">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M12 14l9-5-9-5-9 5 9 5z" /><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /></svg>
          </span>
          {t('userMenu.links.educationalPanel')}
        </a>
      )}

      {isStaff && (
        <a href={`/${lang}/mod/reports`} class="flex items-center gap-3 px-4 py-3 text-[11px] font-bold text-blue-400 hover:bg-blue-500/5 rounded-2xl transition-all uppercase tracking-widest group">
          <span class="p-2 rounded-xl bg-blue-500/10 group-hover:bg-blue-500/20 transition-all shadow-inner">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </span>
           {t('userMenu.links.securityReports')}
        </a>
      )}

      {currentRole === "admin" && (
      <a href={`/${lang}/admin/dashboard`} class="flex items-center gap-3 px-4 py-3 text-[11px] font-bold text-purple-400 hover:bg-purple-500/5 rounded-2xl transition-all uppercase tracking-widest group">
        <span class="p-2 rounded-xl bg-purple-500/10 group-hover:bg-purple-500/20 transition-all shadow-inner">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </span>
        {t('userMenu.links.adminPanel')}
      </a>
      )}

      <div class="h-[1px] bg-white/5 my-2 mx-4"></div>

      <form method="POST" action="/api/auth/signout" class="m-0">
        <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 text-[11px] font-bold text-red-500/60 hover:text-red-400 hover:bg-red-500/10 rounded-2xl transition-all uppercase tracking-widest group text-left">
          <span class="p-2 rounded-xl bg-red-500/10 group-hover:bg-red-500/20 transition-all shadow-inner">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          </span>
          {t('userMenu.links.signout')}
        </button>
      </form>
    </nav>
  </div>
</div>