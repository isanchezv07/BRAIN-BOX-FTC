---
// @Isanchezv
// src/pages/[locale]/auth/signout.astro
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

Astro.cookies.delete("sb-access-token", { path: "/" });
Astro.cookies.delete("sb-refresh-token", { path: "/" });

---

<Layout title={t('auth.signout.title')}>
  <section class="min-h-screen flex items-center justify-center bg-[#050505]">
    <div class="bg-[#0a0a0a] p-10 rounded-[3rem] border border-white/5 shadow-2xl w-full max-w-sm text-center relative overflow-hidden">
      
      <div class="absolute -top-24 -left-24 w-48 h-48 bg-red-600/10 blur-[80px] rounded-full"></div>

      <div class="relative z-10">
        <div class="flex justify-center mb-6">
          <div class="w-12 h-12 border-4 border-red-500/30 border-t-red-500 rounded-full animate-spin"></div>
        </div>

        <h1 class="text-xl font-black text-white italic uppercase tracking-tighter mb-2">
          {t('auth.signout.loading')}
        </h1>

        <form method="POST" action="/api/auth/signout" class="mt-8">
          <button
            type="submit"
            class="w-full py-4 bg-white/5 border border-white/10 text-red-500 font-black uppercase italic text-[10px] rounded-2xl hover:bg-red-500 hover:text-white transition-all tracking-widest"
          >
            {t('auth.signout.button')}
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>