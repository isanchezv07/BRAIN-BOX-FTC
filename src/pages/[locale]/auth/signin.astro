---
// @Isanchezv
// src/pages/[locale]/auth/signin.astro
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const error = Astro.url.searchParams.get("error");
---

<Layout title={`${t('auth.signin.button')}`}>
  <main class="min-h-[90vh] flex flex-col items-center justify-center px-6">
    <div class="relative max-w-md w-full p-10 md:p-12 bg-[#0a0a0a] border border-white/5 rounded-[3.5rem] shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-500">
      
      <div class="absolute -top-24 -right-24 w-48 h-48 bg-blue-600/10 blur-[80px] rounded-full pointer-events-none"></div>

      <div class="relative z-10">
        <header class="text-center mb-10">
          <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter leading-none mb-3">
            {t('auth.signin.title')} <span class="text-blue-500 text-glow">{t('auth.signin.titleHighlight')}</span>
          </h1>
          <p class="text-[9px] text-gray-500 uppercase font-black tracking-[0.3em] italic">
            {t('auth.signin.subtitle')}
          </p>
        </header>
        
        {error && (
          <div class="bg-red-500/10 border border-red-500/20 text-red-500 text-[10px] font-black uppercase tracking-widest p-4 rounded-2xl mb-8 text-center animate-shake italic">
            {error}
          </div>
        )}

        <div class="flex gap-2 p-1.5 bg-black border border-white/5 rounded-[1.5rem] mb-8">
          <button id="tab-password" class="flex-1 py-3 text-[9px] font-black uppercase tracking-widest rounded-xl bg-white/5 text-white transition-all shadow-inner">
            STANDARD
          </button>
          <button id="tab-otp" class="flex-1 py-3 text-[9px] font-black uppercase tracking-widest rounded-xl text-gray-600 hover:text-white transition-all">
            MOD OTP
          </button>
          <button id="tab-google" class="flex-1 py-3 text-[9px] font-black tracking-widest rounded-xl text-gray-600 hover:text-white transition-all uppercase">
            GOOGLE
          </button>
        </div>

        <form id="auth-form" method="POST" action="/api/auth/signin" data-astro-reload class="space-y-5">
          <input type="hidden" name="lang" value={lang} />
          
          <div id="section-email" class="space-y-2 transition-all duration-300">
            <label class="text-[9px] font-black text-gray-600 uppercase tracking-[0.2em] ml-4">
              {t('auth.signin.labels.email')}
            </label>
            <input 
              id="input-email"
              name="email" 
              type="email" 
              placeholder={t('auth.signin.placeholders.email')} 
              required 
              class="w-full p-5 rounded-2xl bg-black border border-white/10 text-white outline-none focus:border-blue-500/50 focus:ring-4 focus:ring-blue-500/5 transition-all font-bold text-sm italic placeholder:text-gray-800" 
            />
          </div>

          <div id="section-password" class="space-y-2 animate-in fade-in slide-in-from-bottom-2 duration-300">
            <div class="flex justify-between items-center px-4">
              <label class="text-[9px] font-black text-gray-600 uppercase tracking-[0.2em]">
                {t('auth.signin.labels.password')}
              </label>
              <a href={`/${lang}/auth/forgot-password`} class="text-[9px] font-black text-blue-500/50 hover:text-blue-500 uppercase tracking-widest transition-colors italic">
                {t('auth.signin.labels.forgot')}
              </a> 
            </div>
            <input 
              id="input-password"
              name="password" 
              type="password" 
              placeholder="••••••••" 
              required
              class="w-full p-5 rounded-2xl bg-black border border-white/10 text-white outline-none focus:border-blue-500/50 transition-all font-bold placeholder:text-gray-800" 
            />
          </div>

          <div id="section-otp" class="space-y-2 hidden animate-in fade-in slide-in-from-bottom-2 duration-300">
            <label class="text-[9px] font-black text-gray-600 uppercase tracking-[0.2em] ml-4 text-center block">
              {t('auth.signin.labels.otp')}
            </label>
            <input 
              id="input-otp"
              name="otp" 
              type="text" 
              placeholder="000000" 
              maxlength="6"
              class="w-full p-5 rounded-2xl bg-black border border-blue-600/30 text-blue-500 font-black text-center text-2xl tracking-[0.6em] outline-none focus:border-blue-500 transition-all placeholder:text-gray-900" 
            />
            <p class="text-[8px] text-gray-700 text-center uppercase mt-3 tracking-widest leading-relaxed px-4">
              {t('auth.signin.labels.otpNote')}
            </p>
          </div>

          <div id="section-google" class="hidden animate-in fade-in zoom-in duration-300 py-4 space-y-6">
            <div class="flex flex-col items-center justify-center">
              <div class="w-20 h-20 bg-white/5 border border-white/10 rounded-[2rem] flex items-center justify-center mb-4 shadow-inner">
                <svg class="w-10 h-10" viewBox="0 0 24 24">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              </div>
              <p class="text-[10px] text-gray-500 uppercase font-black tracking-widest italic text-center leading-relaxed">
                Connect via Google <br/> Secure Protocol
              </p>
            </div>
            
            <button 
              type="button"
              onclick="window.location.href='/api/auth/google'"
              class="group w-full py-5 bg-white text-black font-black uppercase italic rounded-2xl hover:bg-blue-600 hover:text-white transition-all active:scale-[0.98] flex items-center justify-center gap-3 text-xs tracking-widest shadow-xl"
            >
              Continue to Academy
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </div>
          
          <button 
            id="btn-submit"
            type="submit" 
            class="group relative w-full py-5 bg-blue-600 text-black font-black uppercase italic rounded-2xl hover:bg-white transition-all active:scale-[0.98] shadow-2xl shadow-blue-900/20 overflow-hidden mt-6 tracking-widest text-xs"
          >
            <span class="relative z-10">{t('auth.signin.button')}</span>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>
          </button>
        </form>

        <p class="mt-8 text-center text-[10px] text-gray-600 uppercase font-black tracking-widest italic">
          New here? <a href={`/${lang}/auth/register`} class="text-blue-500 hover:text-white transition-colors underline underline-offset-4">Join the Academy</a>
        </p>
      </div>
    </div>
  </main>
</Layout>

<script>
  const setupTabs = () => {
    const tabPassword = document.getElementById('tab-password');
    const tabOtp = document.getElementById('tab-otp');
    const tabGoogle = document.getElementById('tab-google');

    const sectionEmail = document.getElementById('section-email');
    const sectionPassword = document.getElementById('section-password');
    const sectionOtp = document.getElementById('section-otp');
    const sectionGoogle = document.getElementById('section-google');
    
    const btnSubmit = document.getElementById('btn-submit');
    const inputEmail = document.getElementById('input-email') as HTMLInputElement;
    const inputPassword = document.getElementById('input-password') as HTMLInputElement;
    const inputOtp = document.getElementById('input-otp') as HTMLInputElement;

    const activateTab = (mode: 'password' | 'otp' | 'google') => {
      [tabPassword, tabOtp, tabGoogle].forEach(tab => {
        tab?.classList.remove('bg-white/5', 'text-white', 'shadow-inner');
        tab?.classList.add('text-gray-600');
      });

      const currentTab = mode === 'password' ? tabPassword : mode === 'otp' ? tabOtp : tabGoogle;
      currentTab?.classList.add('bg-white/5', 'text-white', 'shadow-inner');
      currentTab?.classList.remove('text-gray-600');

      sectionEmail?.classList.toggle('hidden', mode === 'google');
      sectionPassword?.classList.toggle('hidden', mode !== 'password');
      sectionOtp?.classList.toggle('hidden', mode !== 'otp');
      sectionGoogle?.classList.toggle('hidden', mode !== 'google');
      btnSubmit?.classList.toggle('hidden', mode === 'google');

      if (inputEmail) inputEmail.required = mode !== 'google';
      if (inputPassword) {
        inputPassword.required = mode === 'password';
        if (mode !== 'password') inputPassword.value = "";
      }
      if (inputOtp) {
        inputOtp.required = mode === 'otp';
        if (mode !== 'otp') inputOtp.value = "";
      }
    };

    tabPassword?.addEventListener('click', () => activateTab('password'));
    tabOtp?.addEventListener('click', () => activateTab('otp'));
    tabGoogle?.addEventListener('click', () => activateTab('google'));
  };

  setupTabs();
  document.addEventListener('astro:after-swap', setupTabs);
</script>

<style>
  .text-glow { text-shadow: 0 0 15px rgba(37, 99, 235, 0.5); }
  @keyframes shimmer { 100% { transform: translateX(100%); } }
  .animate-shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
  @keyframes shake {
    10%, 90% { transform: translate3d(-1px, 0, 0); }
    20%, 80% { transform: translate3d(2px, 0, 0); }
    30%, 50%, 70% { transform: translate3d(-3px, 0, 0); }
    40%, 60% { transform: translate3d(3px, 0, 0); }
  }
</style>