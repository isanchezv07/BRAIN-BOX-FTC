---
// @Isanchezv
// src/pages/[locale]/alliance/builder-teams.astro
import Layout from "@/layouts/Layout.astro";
import { getFullTeamIntelligence } from "@/lib/ftc";

const teamsParam = Astro.url.searchParams.get("teams") || "";
const rivalsParam = Astro.url.searchParams.get("rivals") || "";

const teamNumbers = teamsParam.split(",").filter(Boolean);
const rivalNumbers = rivalsParam.split(",").filter(Boolean);

async function fetchAll(numbers) {
  return await Promise.all(numbers.map(async (num) => {
    const data = await getFullTeamIntelligence(num);
    return {
      profile: data.profile,
      summary: data.summary || { peakScore: 0, winRate: "0%", totalAwards: 0, totalLosses: 0 }
    };
  }));
}

const allianceData = await fetchAll(teamNumbers);
const rivalData = await fetchAll(rivalNumbers);

const rawTeamsJson = JSON.stringify(allianceData);
const rawRivalsJson = JSON.stringify(rivalData);

const metricConfig = [
  { id: 'auto', label: 'Autónomo', color: '#3b82f6', text: 'text-blue-500', desc: 'Basado en el 35% del Peak Score vs el Benchmark.' },
  { id: 'teleop', label: 'TeleOp', color: '#22c55e', text: 'text-green-500', desc: 'Basado en el 65% del Peak Score vs el Benchmark.' },
  { id: 'endgame', label: 'Premios', color: '#a855f7', text: 'text-purple-500', desc: 'Cantidad de premios obtenidos vs meta de temporada.' },
  { id: 'consistency', label: 'Consistencia', color: '#eab308', text: 'text-yellow-500', desc: 'Win Rate ajustado por penalización de derrotas.' },
  { id: 'defense', label: 'Resiliencia', color: '#ef4444', text: 'text-red-500', desc: 'Capacidad de mantener el score pese a las derrotas.' },
];
---

<Layout title="WINNER PREDICTION">
  <script src="https://cdn.jsdelivr.net/npm/chart.js" is:inline></script>
  
  <main class="bg-black text-white min-h-screen p-4 sm:p-8 md:p-12 lg:p-20 font-sans relative overflow-x-hidden">
    <div class="fixed inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] pointer-events-none"></div>

    <header class="mb-12 md:mb-20 relative z-10">
      <div class="flex justify-between items-center mb-8">
        <a href="/" class="group text-zinc-500 font-black uppercase text-[10px] tracking-widest hover:text-blue-500 transition-colors flex items-center gap-4">
          <span class="w-8 md:w-10 h-px bg-zinc-800 group-hover:w-16 group-hover:bg-blue-500 transition-all"></span> 
          Back_to_Intel
        </a>
      </div>

      <h1 class="text-[12vw] md:text-[8rem] font-black italic uppercase tracking-tighter leading-[0.8] mb-12">
        Winner <br/>
        <span class="text-transparent [-webkit-text-stroke:1px_rgba(255,255,255,0.2)]">Prediction</span>
      </h1>

      <div class="max-w-5xl space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-blue-500/5 p-3 rounded-2xl border border-blue-500/20 flex gap-2 backdrop-blur-sm">
            <input id="teamInput" type="number" placeholder="BLUE_ALLIANCE_ID" class="bg-transparent border-none px-4 py-3 focus:ring-0 text-white font-mono flex-1" />
            <button id="addBtn" class="bg-blue-600 hover:bg-blue-400 text-black px-6 py-4 rounded-xl font-black uppercase text-[10px] tracking-widest transition-all">Add_Blue</button>
          </div>
          <div id="rivalInputContainer" class="hidden bg-red-500/5 p-3 rounded-2xl border border-red-500/20 flex gap-2 backdrop-blur-sm">
            <input id="rivalInput" type="number" placeholder="RED_ALLIANCE_ID" class="bg-transparent border-none px-4 py-3 focus:ring-0 text-white font-mono flex-1" />
            <button id="addRivalBtn" class="bg-red-600 hover:bg-red-400 text-black px-6 py-4 rounded-xl font-black uppercase text-[10px] tracking-widest transition-all">Add_Red</button>
          </div>
        </div>

        <div class="flex flex-wrap gap-6 items-center">
            <button id="toggleCalibration" class="text-[10px] font-black uppercase tracking-[0.2em] text-zinc-500 hover:text-white flex items-center gap-2 group">
              <span class="w-4 h-4 rounded-full border border-zinc-700 flex items-center justify-center text-[8px] group-hover:border-blue-500">i</span>
              Adjust_Benchmarks
            </button>
            <button id="enableBattle" class="text-[10px] font-black uppercase tracking-[0.2em] text-red-500 hover:text-red-400 flex items-center gap-2">
                ⚔️ Start_Engagement_Mode
            </button>
        </div>

        <div id="calibrationPanel" class="hidden p-8 bg-zinc-900/80 border border-white/10 rounded-3xl backdrop-blur-3xl">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-8">
            <div class="space-y-6">
              <h4 class="text-blue-500 font-black text-xs uppercase tracking-widest">Target Benchmarks</h4>
              <div class="space-y-1">
                <label class="flex justify-between text-[9px] font-bold uppercase text-zinc-400">Auto Target <span id="val-auto" class="text-blue-500 font-mono">100</span></label>
                <input type="range" id="bench-auto" min="20" max="250" value="100" class="w-full">
              </div>
              <div class="space-y-1">
                <label class="flex justify-between text-[9px] font-bold uppercase text-zinc-400">TeleOp Target <span id="val-teleop" class="text-green-500 font-mono">250</span></label>
                <input type="range" id="bench-teleop" min="0" max="500" value=100" class="w-full">
              </div>
              <div class="space-y-1">
                <label class="flex justify-between text-[9px] font-bold uppercase text-zinc-400">Awards Target <span id="val-awards" class="text-purple-500 font-mono">10</span></label>
                <input type="range" id="bench-awards" min="0" max="50" value="10" class="w-full">
              </div>
              <div class="space-y-1">
                <label class="flex justify-between text-[9px] font-bold uppercase text-zinc-400">Consistency Target (WR%) <span id="val-wr" class="text-yellow-500 font-mono">80</span></label>
                <input type="range" id="bench-wr" min="10" max="100" value="80" class="w-full">
              </div>
            </div>
            
            <div class="space-y-4">
              <h4 class="text-zinc-500 font-black text-xs uppercase tracking-widest italic">// Metric_Logic</h4>
              <div class="grid gap-3">
                {metricConfig.map(m => (
                  <div class="flex gap-4 items-start">
                    <div class={`w-1 h-8 ${m.text} bg-current`}></div>
                    <div>
                      <p class="text-[10px] font-bold uppercase leading-none mb-1">{m.label}</p>
                      <p class="text-[9px] text-zinc-500 leading-tight">{m.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-24 relative z-10">
        <div id="teamGrid" class="space-y-4"></div>
        <div id="rivalGrid" class="space-y-4"></div>
    </div>
    { (allianceData.length > 0 || rivalData.length > 0) && (
      <section class="border-t border-white/5 pt-12 md:pt-20 relative z-10 space-y-12 md:space-y-20">
        <div class="space-y-8">
            <div class="flex items-end gap-4 mb-8">
                <h2 class="text-4xl md:text-6xl font-black italic uppercase tracking-tighter">Collective_Power</h2>
                <div class="h-px flex-1 bg-gradient-to-r from-zinc-800 to-transparent mb-2 md:mb-4"></div>
            </div>
            <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 md:gap-12 relative">
                <div class="hidden xl:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-20 w-12 h-12 bg-black border border-white/10 rounded-full items-center justify-center">
                    <span class="text-[10px] font-black italic text-zinc-500">VS</span>
                </div>
                <div class="bg-blue-500/[0.03] backdrop-blur-md p-6 md:p-8 rounded-[2rem] border border-blue-500/10 hover:border-blue-500/30 transition-colors">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></div>
                        <p class="text-[10px] font-black text-blue-500 uppercase tracking-[0.3em]">Blue_Synergy_Core</p>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3" id="blueSynergy"></div>
                </div>
                <div class="bg-red-500/[0.03] backdrop-blur-md p-6 md:p-8 rounded-[2rem] border border-red-500/10 hover:border-red-500/30 transition-colors">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></div>
                        <p class="text-[10px] font-black text-red-500 uppercase tracking-[0.3em]">Red_Synergy_Core</p>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3" id="redSynergy"></div>
                </div>
            </div>
        </div>
    
        <div id="predictionBox" class="w-full bg-zinc-900 border border-white/10 p-1.5 rounded-[2.5rem] md:rounded-[4rem] overflow-hidden shadow-2xl transition-all duration-700">
          <div class="bg-blue-600 p-8 md:p-16 lg:p-20 rounded-[2.2rem] md:rounded-[3.8rem] flex flex-col lg:flex-row justify-between items-center gap-10 text-black transition-colors duration-700">
            <div class="text-center lg:text-left flex-1 min-w-0 space-y-4 md:space-y-6">
              <div class="space-y-1">
                  <p class="text-[8px] md:text-[10px] font-black uppercase tracking-[0.3em] text-black/40 flex items-center justify-center lg:justify-start gap-2">
                      <span class="w-2 h-[1px] bg-black/20"></span>
                      Neural_Network_Output
                  </p>
                  <h3 id="predictionTitle" class="text-4xl sm:text-6xl lg:text-7xl xl:text-8xl font-black italic uppercase tracking-tighter leading-none break-words">
                      Match_Ready
                  </h3>
              </div>
              <div class="max-w-sm mx-auto lg:mx-0">
                  <p id="predictionSub" class="text-[9px] md:text-[11px] font-bold uppercase tracking-[0.15em] opacity-70 leading-relaxed italic border-l-2 border-black/30 pl-4 py-1">
                      Analizando variables de campo y consistencia de los drivers...
                  </p>
              </div>
            </div>
            <div class="flex flex-col sm:flex-row items-center gap-6 md:gap-8 bg-black p-8 md:p-10 rounded-[2rem] md:rounded-[3rem] border border-white/10 shadow-2xl w-full lg:w-auto">
                <div class="text-center flex-1 sm:flex-none">
                    <p class="text-[8px] md:text-[9px] font-black uppercase mb-1 text-zinc-500 tracking-widest">Blue_Win</p>
                    <p id="blueProb" class="text-6xl md:text-7xl font-black italic tracking-tighter text-blue-500">50%</p>
                </div>
                <div class="h-px w-12 sm:h-16 sm:w-px bg-zinc-800"></div>
                
                <div class="text-center flex-1 sm:flex-none">
                    <p class="text-[8px] md:text-[9px] font-black uppercase mb-1 text-zinc-500 tracking-widest">Red_Win</p>
                    <p id="redProb" class="text-6xl md:text-7xl font-black italic tracking-tighter text-red-500">50%</p>
                </div>
            </div>
          </div>
        </div>
      </section>
    )}
  </main>
</Layout>

<script is:inline define:vars={{ rawTeamsJson, rawRivalsJson, metricConfig }}>
  const allianceData = JSON.parse(rawTeamsJson);
  const rivalData = JSON.parse(rawRivalsJson);
  let benchmarks = { auto: 100, teleop: 250, awards: 10, wr: 80 };

  function getMetrics(team) {
    const peak = team.summary.peakScore || 0;
    const losses = team.summary.totalLosses || 0;
    const penalty = Math.min(25, losses * 2.5);
    
    return {
      auto: Math.min(100, Math.round(((peak * 0.35) / benchmarks.auto) * 100)),
      teleop: Math.min(100, Math.round(((peak * 0.65) / benchmarks.teleop) * 100)),
      endgame: Math.min(100, Math.round(((team.summary.totalAwards || 0) / benchmarks.awards) * 100)),
      defense: Math.max(10, 100 - (losses * 8)),
      consistency: Math.max(5, Math.min(100, Math.round(((parseFloat(team.summary.winRate) || 0) / benchmarks.wr) * 100) - penalty))
    };
  }

  function renderSynergyGrid(targetId, dataArr) {
    const container = document.getElementById(targetId);
    if (!container) return { power: 0 };
    
    if (!dataArr.length) {
        container.innerHTML = `<div class="col-span-full py-4 text-zinc-700 font-black italic uppercase text-[10px] tracking-[0.3em]">No_Data_Available</div>`;
        return { power: 0 };
    }

    const sums = dataArr.reduce((acc, t) => {
        const m = getMetrics(t);
        Object.keys(m).forEach(k => acc[k] = (acc[k] || 0) + m[k]);
        return acc;
    }, {});

    const avgs = {};
    Object.keys(sums).forEach(k => avgs[k] = Math.round(sums[k] / dataArr.length));

    container.innerHTML = metricConfig.map(m => `
        <div class="bg-black/40 border border-white/5 p-4 rounded-xl relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-1 h-full ${m.text} opacity-20"></div>
            <p class="text-[7px] font-black text-zinc-500 uppercase tracking-widest mb-1 italic">${m.label}</p>
            <p class="text-3xl font-black italic leading-none ${m.text}">${avgs[m.id] || 0}%</p>
        </div>
    `).join('');

    const alliancePower = dataArr.reduce((acc, t) => acc + (t.summary.peakScore || 0), 0);
    return { power: alliancePower };
  }

  function updateBattleStats() {
    const blue = renderSynergyGrid('blueSynergy', allianceData);
    const red = renderSynergyGrid('redSynergy', rivalData);
    
    function boxMuller(mean, sigma) {
      let u = 0, v = 0, s = 0;
      do { u = Math.random() * 2 - 1; v = Math.random() * 2 - 1; s = u * u + v * v; } while (s >= 1 || s === 0);
      return mean + u * Math.sqrt(-2.0 * Math.log(s) / s) * sigma;
    }

    const eventMean = (benchmarks.auto + benchmarks.teleop) || 80;
    const sigma = Math.max(8, eventMean * 0.16);
    let blueWins = 0;
    const runs = 500;

    for (let i = 0; i < runs; i++) {
      if (boxMuller(blue.power, sigma) > boxMuller(red.power, sigma)) blueWins++;
    }

    const finalBlueProb = Math.round((blueWins / runs) * 100);
    const finalRedProb = 100 - finalBlueProb;

    document.getElementById('blueProb').innerText = `${finalBlueProb}%`;
    document.getElementById('redProb').innerText = `${finalRedProb}%`;

    updatePredictionVisuals(finalBlueProb);
  }

  function createCard(team, isBlue) {
    const metrics = getMetrics(team);
    const theme = isBlue 
      ? { 
          border: 'hover:border-blue-500/30', 
          text: 'group-hover:text-blue-500',
          accent: 'blue' 
        } 
      : { 
          border: 'hover:border-red-500/30', 
          text: 'group-hover:text-red-500',
          accent: 'red' 
        };
    
    return `
      <div class="bg-zinc-900/40 border border-white/5 p-6 rounded-[2rem] backdrop-blur-md ${theme.border} transition-all group">
        <div class="flex justify-between items-start mb-6">
          <div>
            <h2 class="text-2xl font-black italic uppercase leading-none tracking-tighter ${theme.text} transition-colors">
                ${team.profile.nameShort}
            </h2>
            <p class="text-zinc-600 font-mono text-sm tracking-widest mt-1">#${team.profile.teamNumber}</p>
          </div>
          <button onclick="window.removeUnit('${isBlue ? 'teams' : 'rivals'}', ${team.profile.teamNumber})" class="bg-white/5 hover:bg-red-500 text-zinc-500 hover:text-white p-2 rounded-lg transition-all">
             <svg 
              width="14" 
              height="14" 
              viewBox="0 0 24 24" 
              fill="none" 
              stroke="currentColor" 
              stroke-width="3" 
              stroke-linecap="round" 
              stroke-linejoin="round"
            >
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
        
        <div class="grid grid-cols-5 gap-4 items-center">
            <div class="col-span-3 space-y-3">
                ${metricConfig.map(m => `
                    <div class="space-y-1">
                        <div class="flex justify-between text-[7px] font-black uppercase text-zinc-500 tracking-tighter">
                          <span>${m.label}</span>
                          <span class="${m.text}">${metrics[m.id]}%</span>
                        </div>
                        <div class="h-[2px] w-full bg-white/5 rounded-full">
                            <div class="h-full transition-all duration-1000" style="width: ${metrics[m.id]}%; background: ${m.color}"></div>
                        </div>
                    </div>
                `).join('')}
            </div>
            <div class="col-span-2 aspect-square p-2">
                <canvas id="chart-${team.profile.teamNumber}"></canvas>
            </div>
        </div>
      </div>
    `;
  }

  function initChart(team, color) {
    const ctx = document.getElementById(`chart-${team.profile.teamNumber}`);
    if (!ctx) return;
    const metrics = getMetrics(team);
    
    new Chart(ctx, {
      type: 'radar',
      data: {
        labels: metricConfig.map(m => m.label),
        datasets: [{
          data: Object.values(metrics),
          backgroundColor: `${color}20`,
          borderColor: color,
          borderWidth: 2,
          pointRadius: 2,
          pointBackgroundColor: color
        }]
      },
      options: {
        scales: {
          r: {
            min: 0,
            max: 100,
            beginAtZero: true,
            grid: { color: 'rgba(255,255,255,0.05)' },
            angleLines: { color: 'rgba(255,255,255,0.05)' },
            ticks: { display: false },
            pointLabels: { display: false }
          }
        },
        plugins: { legend: { display: false }, tooltip: { enabled: true } }
      }
    });
  }

  function render() {
    const bGrid = document.getElementById('teamGrid');
    const rGrid = document.getElementById('rivalGrid');
  
    if (bGrid) bGrid.innerHTML = allianceData.map(t => createCard(t, true)).join('');
    if (rGrid) rGrid.innerHTML = rivalData.map(t => createCard(t, false)).join('');
    
    allianceData.forEach(t => initChart(t, '#3b82f6'));
    rivalData.forEach(t => initChart(t, '#ef4444'));
    
    updateBattleStats();
  }

  ['auto', 'teleop', 'awards', 'wr'].forEach(key => {
    const slider = document.getElementById(`bench-${key}`);
    const display = document.getElementById(`val-${key}`);
    
    if (slider) {
      slider.addEventListener('input', (e) => {
        const value = parseInt(e.target.value);
        benchmarks[key] = value;
        
        if (display) {
            display.innerText = value + (key === 'wr' ? '%' : '');
        }
        
        render();
      });
    }
  });

  document.getElementById('addBtn').onclick = () => add('teams', 'teamInput');
  document.getElementById('addRivalBtn').onclick = () => add('rivals', 'rivalInput');
  
  function add(param, inputId) {
    const val = document.getElementById(inputId).value.trim();
    if (!val) return;
    const url = new URL(window.location);
    const current = url.searchParams.get(param) ? url.searchParams.get(param).split(",") : [];
    if (!current.includes(val)) {
      current.push(val);
      url.searchParams.set(param, current.join(","));
      window.location.href = url.href;
    }
  }

  window.removeUnit = (param, num) => {
    const url = new URL(window.location);
    const list = url.searchParams.get(param).split(",").filter(t => t != num);
    list.length ? url.searchParams.set(param, list.join(",")) : url.searchParams.delete(param);
    window.location.href = url.href;
  };

  document.getElementById('enableBattle').onclick = () => document.getElementById('rivalInputContainer').classList.toggle('hidden');
  document.getElementById('toggleCalibration').onclick = () => document.getElementById('calibrationPanel').classList.toggle('hidden');

  ['auto', 'teleop', 'awards', 'wr'].forEach(key => {
    const slider = document.getElementById(`bench-${key}`);
    if (slider) {
      slider.addEventListener('input', (e) => {
        benchmarks[key] = parseInt(e.target.value);
        const display = document.getElementById(`val-${key}`);
        if (display) display.innerText = e.target.value + (key === 'wr' ? '%' : '');
        render(); 
      });
    }
  });

  if (new URL(window.location).searchParams.get('rivals')) document.getElementById('rivalInputContainer').classList.remove('hidden');
  render();
</script>

<style>
  input[type=range] { -webkit-appearance: none; background: transparent; height: 20px; }
  input[type=range]::-webkit-slider-thumb { 
    appearance: none; width: 12px; height: 12px; background: #fff; 
    border-radius: 2px; cursor: pointer; border: none; margin-top: -5px;
    box-shadow: 0 0 10px rgba(59, 130, 246, 0.5);
  }
  input[type=range]::-webkit-slider-runnable-track { 
    width: 100%; height: 2px; background: rgba(255,255,255,0.05); 
  }
</style>