---
// @Isanchezv
// src/pages/[locale]/teacher/portfolio-ai.astro
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { supabase } from "@/lib/supabase";

const { locale } = Astro.params;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { data: { user } } = await supabase.auth.getUser();
const { data: profile } = await supabase
  .from("profiles")
  .select("scanner_usage_count, role")
  .eq(user?.id ? "id" : "", user?.id)
  .single();

const isAdmin = profile?.role === 'admin';
const usageCount = profile?.scanner_usage_count || 0;
const limit = 3; 
const isLocked = !isAdmin && usageCount >= limit;
const remaining = isAdmin ? "∞" : Math.max(0, limit - usageCount);

const tourData = {
  nextBtnText: t('tour.btns.next'),
  prevBtnText: t('tour.btns.prev'),
  doneBtnText: t('tour.btns.done'),
  steps: [
    { 
      element: '#tour-step-1', 
      title: t('tour.step1.title'), 
      desc: t('tour.step1.desc') 
    },
    { 
      element: '#tour-step-2', 
      title: t('tour.step2.title'), 
      desc: t('tour.step2.desc') 
    },
    { 
      element: '#tour-step-3', 
      title: t('tour.step3.title'), 
      desc: t('tour.step3.desc') 
    },
    { 
      element: '#tour-step-4', 
      title: t('tour.step4.title'), 
      desc: t('tour.step4.desc') 
    }
  ]
};
---

<Layout title={t('scanner.title')}>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.0.1/dist/driver.css"/>

  <div id="tour-config" data-translations={JSON.stringify(tourData)}></div>

  <main class="min-h-screen bg-[#050505] py-20 px-6 relative overflow-hidden">

    <nav class="flex items-left mb-10 ml-0 md:ml-80">
      <a href={`/${lang}/account/dashboard`} class="inline-flex items-center gap-3 text-[10px] font-black text-gray-500 hover:text-white transition-all uppercase tracking-[0.2em] group">
        <div class="flex items-center justify-center w-8 h-8 rounded-full bg-white/5 border border-white/5 group-hover:border-blue-500/50 group-hover:bg-blue-500/10 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </div>
        {t('course.nav.back')}
      </a>
    </nav>
    <button id="replay-tour-btn" class="fixed bottom-8 right-8 z-[9999] hidden items-center gap-3 text-[10px] font-black text-white hover:text-white transition-all uppercase tracking-[0.2em] group bg-blue-500/50 backdrop-blur-md border border-white/5 px-4 py-3 rounded-full hover:border-blue-500/50 hover:bg-blue-500/10 shadow-2xl">
      {t('tour.btns.replay') || '¿Repetir Tour?'}
    </button>

    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-96 bg-blue-500/10 blur-[120px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto relative z-10">
      <header class="mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div id="tour-step-1" class="flex items-center gap-4">
          <h1 class="text-6xl md:text-7xl font-black italic text-white uppercase leading-none">
            {t('scanner.title')} <span class="text-blue-500">{t('scanner.highlight')}</span>
          </h1>
          <span class="px-4 py-1 rounded-full border border-purple-500/40 bg-purple-500/10 text-purple-400 text-[11px] font-black uppercase tracking-[0.3em] italic shadow-[0_0_15px_rgba(168,85,247,0.15)]">
            Beta
          </span>
        </div>

        <div id="tour-step-2" class="bg-white/5 p-4 rounded-2xl border border-white/5 w-full md:w-auto">
            <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2">{t('scanner.credits')}</p>
            <div class="flex gap-1.5 justify-start md:justify-end">
                {isAdmin ? (
                    <div class="h-4 flex items-center gap-1">
                        <span class="text-blue-500 text-[10px] font-black italic">UNLIMITED ADMIN</span>
                    </div>
                ) : (
                    Array.from({ length: limit }).map((_, i) => (
                        <div class={`w-2 h-5 rounded-sm skew-x-[-20deg] transition-all duration-700 ${i < usageCount ? 'bg-white/10' : 'bg-blue-600 shadow-[0_0_15px_rgba(37,99,235,0.6)] border border-blue-400'}`}></div>
                    ))
                )}
            </div>
            <p class="text-white font-black italic mt-1 text-right text-xs">{remaining} {!isAdmin && `/ ${limit}`}</p>
        </div>
      </header>

      <div id="tour-step-3" class="mb-8 animate-in fade-in slide-in-from-top-4 duration-700">
        <label for="awardSelector" class="text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] mb-3 block ml-4 italic">
          {t('scanner.objective')}
        </label>
        <div class="relative group">
          <select id="awardSelector" class="w-full bg-white/5 border border-white/10 text-white font-black italic uppercase text-sm rounded-2xl px-6 py-4 appearance-none focus:outline-none focus:border-blue-500/50 transition-all cursor-pointer hover:bg-white/[0.08]">
            <option value="Inspire Award" selected>Inspire Award</option>
            <option value="Nivel World Champion">General</option>
            <option value="Think Award">Think Award</option>
            <option value="Connect Award">Connect Award</option>
            <option value="Innovate Award (RTX)">Innovate Award (RTX)</option>
            <option value="Control Award">Control Award</option>
            <option value="Design Award">Design Award</option>
            <option value="Reach Award">Reach Award</option>
            <option value="Sustain Award">Sustain Award</option>
          </select>
          <div class="absolute right-6 top-1/2 -translate-y-1/2 pointer-events-none text-blue-500">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
        </div>
      </div>

      <div id="tour-step-4">
        <div id="dropzone" data-locked={isLocked ? "true" : "false"} class={`group relative border-2 border-dashed rounded-[2.5rem] p-16 text-center transition-all duration-500 
          ${isLocked ? 'border-red-500/40 bg-red-500/[0.03] cursor-not-allowed' : 'border-white/10 bg-white/[0.02] hover:bg-white/[0.05] hover:border-blue-500/50 cursor-pointer'}`}>
          
          {!isLocked && <input type="file" id="fileInput" class="hidden" accept=".pdf" />}
          
          <div id="idle-state" class="space-y-4 pointer-events-none">
            {isLocked ? (
              <div class="animate-in fade-in zoom-in duration-500">
                  <div class="w-20 h-20 mx-auto bg-red-500/10 border border-red-500/20 rounded-full flex items-center justify-center mb-6 shadow-[0_0_30px_rgba(239,68,68,0.2)]">
                    <span class="text-4xl">🔒</span>
                  </div>
                  <h3 class="text-2xl font-black text-white italic uppercase tracking-tighter">
                    Límite <span class="text-red-500 text-3xl">Agotado</span>
                  </h3>
                  <p class="text-gray-500 text-xs mt-2 uppercase font-bold tracking-widest leading-relaxed">No tienes más créditos para el análisis de portafolio.<br/>Contacta a soporte para recargar.</p>
              </div>
            ) : (
              <>
                <div class="text-6xl group-hover:scale-110 transition-transform duration-500 drop-shadow-[0_0_15px_rgba(255,255,255,0.1)]">📄</div>
                <p class="text-white font-black tracking-[0.2em] text-sm uppercase">{t('scanner.dropzone.idle')}</p>
                <p class="text-gray-500 text-[10px] uppercase font-bold tracking-[0.3em]">Arrastra tu PDF o haz click aquí</p>
              </>
            )}
          </div>
          
          <div id="loading-state" class="hidden space-y-6">
            <div class="relative w-20 h-20 mx-auto">
              <div class="absolute inset-0 border-4 border-blue-500/10 rounded-full"></div>
              <div class="absolute inset-0 border-4 border-blue-500 rounded-full border-t-transparent animate-spin"></div>
              <div class="absolute inset-4 border-2 border-blue-300/20 rounded-full animate-pulse"></div>
            </div>
            <div class="space-y-2">
              <p class="text-blue-500 font-black animate-pulse tracking-[0.3em] uppercase text-sm italic">{t('scanner.loading')}</p>
              <p class="text-[10px] text-gray-500 uppercase font-bold tracking-widest">Analizando Visión de Jueces y Rúbricas...</p>
            </div>
          </div>
        </div>
      </div>

      <div id="results-area" class="hidden mt-16 space-y-20 animate-in fade-in slide-in-from-bottom-10 duration-1000 pb-20">
    
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-[#0a0a0a] p-10 rounded-[2.5rem] text-center border border-blue-500/20 shadow-[0_0_50px_rgba(37,99,235,0.05)]">
                <p class="text-blue-500 text-[10px] font-black mb-2 uppercase tracking-[0.2em]">{t('scanner.score.title')}</p>
                <div id="score" class="text-8xl font-black text-white italic drop-shadow-[0_0_20px_rgba(255,255,255,0.1)]">0</div>
                <p id="verdict" class="text-blue-400 text-xs mt-4 font-black uppercase italic tracking-tighter"></p>
            </div>
    
            <div class="md:col-span-2 bg-white/[0.03] p-10 rounded-[2.5rem] border border-white/10 flex flex-col justify-center">
                <p class="text-blue-500 text-[10px] font-black mb-6 uppercase tracking-[0.2em] italic">{t('scanner.compliance.title')}</p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center sm:text-left">
                    <div class="space-y-1">
                        <p class="text-[10px] text-gray-500 uppercase font-bold tracking-widest">{t('scanner.compliance.pages')}</p>
                        <p id="compliance-pages" class="text-white font-black italic uppercase"></p>
                    </div>
                    <div class="space-y-1 border-y sm:border-y-0 sm:border-x border-white/5 py-4 sm:py-0 px-4">
                        <p class="text-[10px] text-gray-500 uppercase font-bold tracking-widest">{t('scanner.compliance.coverage')}</p>
                        <p id="compliance-coverage" class="text-white font-black italic uppercase"></p>
                    </div>
                    <div class="space-y-1">
                        <p class="text-[10px] text-gray-500 uppercase font-bold tracking-widest">{t('scanner.compliance.evidence')}</p>
                        <p id="compliance-evidence" class="text-white font-black italic uppercase text-xs"></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-4">
                <h4 class="text-blue-500 font-black italic uppercase text-xs tracking-widest">{t('scanner.analysis.title')}</h4>
                <div class="bg-white/5 p-6 rounded-3xl border border-white/5">
                   <p id="analysis" class="text-gray-400 text-sm leading-relaxed italic"></p>
                </div>
            </div>
            <div class="bg-blue-500/5 border border-blue-500/20 p-8 rounded-3xl">
                <h4 class="text-blue-400 font-black italic uppercase text-xs mb-4 tracking-widest">Brecha para el Premio Seleccionado</h4>
                <p id="award-gap" class="text-gray-300 text-sm italic leading-relaxed"></p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-red-500/[0.03] border border-red-500/10 p-6 rounded-3xl">
                <h5 class="text-red-500 font-black text-[10px] uppercase mb-4 italic tracking-widest text-center">{t('scanner.list.critical')}</h5>
                <ul id="critical-list" class="text-[11px] text-gray-400 space-y-3"></ul>
            </div>
            <div class="bg-green-500/[0.03] border border-green-500/10 p-6 rounded-3xl">
                <h5 class="text-green-500 font-black text-[10px] uppercase mb-4 italic tracking-widest text-center">{t('scanner.list.strengths')}</h5>
                <ul id="strengths-list" class="text-[11px] text-gray-400 space-y-3"></ul>
            </div>
            <div class="bg-blue-500/[0.03] border border-blue-500/10 p-6 rounded-3xl">
                <h5 class="text-blue-400 font-black text-[10px] uppercase mb-4 italic tracking-widest text-center">{t('scanner.list.actions')}</h5>
                <ul id="actions-list" class="text-[11px] text-gray-400 space-y-3"></ul>
            </div>
        </div>

        <section class="space-y-8">
            <div class="text-center">
                <h3 class="text-white font-black italic uppercase text-2xl tracking-tighter">Sugerencias de <span class="text-blue-500">Optimización</span></h3>
                <p class="text-gray-500 text-xs uppercase mt-2 tracking-widest font-bold italic">Mejora tu impacto en cada categoría</p>
            </div>
            <div id="suggestions-container" class="grid grid-cols-1 gap-4"></div>
        </section>

        <section class="space-y-8">
            <div class="text-center border-t border-white/5 pt-16">
                <h3 class="text-white font-black italic uppercase text-2xl tracking-tighter">Posibles Preguntas del <span class="text-blue-500">Jurado</span></h3>
                <p class="text-gray-500 text-xs uppercase mt-2 tracking-widest font-bold italic">Prepárate para la entrevista técnica</p>
            </div>
            <div id="questions-container" class="grid grid-cols-1 gap-4"></div>
        </section>

        <button onclick="window.location.reload()" class="w-full py-6 rounded-[2rem] border border-white/10 text-gray-500 font-black uppercase text-xs hover:bg-white/5 transition-colors tracking-[0.3em] italic">
          {t('scanner.btn.retry')} / Analizar otra categoría
        </button>
      </div>
    </div>
  </main>
</Layout>

<script>
  // @ts-nocheck
  import { driver } from "driver.js";

  function initTour() {
    const replayBtn = document.getElementById('replay-tour-btn');
    const configElement = document.getElementById('tour-config');
    
    if (!configElement || !replayBtn) return;

    const tourTranslations = JSON.parse(configElement.dataset.translations);

    const driverConfig = driver({
      showProgress: true,
      animate: true,
      overlayColor: '#000',
      overlayOpacity: 0.9,
      nextBtnText: tourTranslations.nextBtnText,
      prevBtnText: tourTranslations.prevBtnText,
      doneBtnText: tourTranslations.doneBtnText,
      steps: tourTranslations.steps.map(step => ({
        element: step.element,
        popover: {
          title: step.title,
          description: step.desc,
          side: "bottom",
          align: "start"
        }
      })),
      onDestroyed: () => {
        localStorage.setItem('tour_realizado', 'true');
        replayBtn.style.display = 'flex';
      }
    });

    const yaLoVio = localStorage.getItem('tour_realizado');
    if (!yaLoVio) {
      driverConfig.drive();
    } else {
      replayBtn.style.display = 'flex';
    }

    replayBtn.onclick = () => driverConfig.drive();
  }

  function initScannerLogic() {
    const dropzone = document.getElementById('dropzone');
    const fileInput = document.getElementById('fileInput');
    const resultsArea = document.getElementById('results-area');
    const idleState = document.getElementById('idle-state');
    const loadingState = document.getElementById('loading-state');
    const awardSelector = document.getElementById('awardSelector');

    if (!dropzone) return;

    const isLocked = dropzone.getAttribute('data-locked') === "true";

    if (!isLocked) {
      dropzone.onclick = () => fileInput?.click();

      fileInput?.addEventListener('change', (e) => { 
          if (e.target.files?.length) handleFileUpload(e.target.files[0]); 
      });

      ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
          dropzone.addEventListener(eventName, (e) => {
              e.preventDefault();
              e.stopPropagation();
          }, false);
      });

      dropzone.addEventListener('drop', (e) => {
          const file = e.dataTransfer.files[0];
          if (file?.type === "application/pdf") handleFileUpload(file);
          else alert("Error: Por favor sube un archivo PDF válido.");
      });
    }

    async function handleFileUpload(file) {
      if (file.size > 5 * 1024 * 1024) return alert("Máximo 5MB permitido.");
      
      idleState.classList.add('hidden');
      loadingState.classList.remove('hidden');
      resultsArea.classList.add('hidden');

      const formData = new FormData();
      formData.append('portfolio', file);
      formData.append('awardType', awardSelector.value); 

      try {
        const res = await fetch('/api/analyze-portfolio', { method: 'POST', body: formData });
        if (!res.ok) throw new Error("Error en el servidor");
        const data = await res.json();

        loadingState.classList.add('hidden');
        resultsArea.classList.remove('hidden');
        
        document.getElementById('score').innerText = data.score;
        document.getElementById('verdict').innerText = data.verdict;
        document.getElementById('compliance-pages').innerText = data.portfolio_compliance.page_limit;
        document.getElementById('compliance-coverage').innerText = data.portfolio_compliance.content_coverage;
        document.getElementById('compliance-evidence').innerText = data.portfolio_compliance.evidence_quality;
        document.getElementById('analysis').innerText = data.analysis;
        document.getElementById('award-gap').innerText = data.unified_gap || data.gap || "N/A";

        const renderList = (id, items) => {
          const el = document.getElementById(id);
          if (el && items) el.innerHTML = items.map(i => `
            <li class="flex items-start gap-2 italic border-b border-white/5 pb-2 text-[10px] uppercase tracking-tighter">
              <span class="text-blue-500 font-black">•</span> ${i}
            </li>`).join('');
        };

        renderList('critical-list', [...(data.critical_missing || []), ...(data.rule_violations || [])]);
        renderList('strengths-list', data.strengths);
        renderList('actions-list', data.next_actions);

        const containerS = document.getElementById('suggestions-container');
        if (containerS && data.suggestions) {
            let html = '';
            Object.entries(data.suggestions).forEach(([key, items]) => {
                if (Array.isArray(items)) items.forEach(item => {
                    html += `<div class="bg-white/5 border border-white/10 p-6 rounded-3xl mb-4"><p class="text-white font-bold italic mb-2">${item.issue}</p><p class="text-blue-400 text-xs italic">${item.suggested_portfolio_change}</p></div>`;
                });
            });
            containerS.innerHTML = html;
        }

        const containerQ = document.getElementById('questions-container');
        if (containerQ && data.judge_questions) {
            let html = '';
            Object.entries(data.judge_questions).forEach(([key, items]) => {
                if (Array.isArray(items)) items.forEach(item => {
                    html += `<div class="bg-white/5 border border-white/10 p-6 rounded-3xl mb-4"><p class="text-white font-black italic">"${item.question}"</p></div>`;
                });
            });
            containerQ.innerHTML = html;
        }

        setTimeout(() => resultsArea.scrollIntoView({ behavior: 'smooth' }), 300);

      } catch (e) {
        console.error(e);
        idleState.classList.remove('hidden');
        loadingState.classList.add('hidden');
        alert("Error al analizar el archivo.");
      }
    }
  }

  function run() {
    initTour();
    initScannerLogic();
  }

  run();
  document.addEventListener('astro:page-load', run);
</script>

<style is:global>
  .driver-popover {
    background-color: #0a0a0a !important;
    color: white !important;
    border: 1px solid rgba(168, 85, 247, 0.4) !important;
    border-radius: 24px !important;
    padding: 24px !important;
    box-shadow: 0 20px 50px rgba(0,0,0,0.9) !important;
  }
  .driver-popover-title {
    font-weight: 900 !important;
    font-style: italic !important;
    text-transform: uppercase !important;
    color: #a855f7 !important;
    font-size: 18px !important;
  }
  .driver-popover-description {
    color: #d1d5db !important;
    font-size: 14px !important;
    line-height: 1.6 !important;
  }
  .driver-popover-btn {
    background: #111 !important;
    color: white !important;
    border: 1px solid #333 !important;
    font-weight: 800 !important;
    text-transform: uppercase !important;
    font-size: 11px !important;
    border-radius: 12px !important;
  }
  .driver-popover-btn:hover {
    background: #a855f7 !important;
    border-color: #a855f7 !important;
  }
</style>