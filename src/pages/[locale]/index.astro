---
// @Isanchezv
// src/pages/[locale]/index.astro
import Layout from "@/layouts/Layout.astro";
import { supabase } from "@/lib/supabase";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");
let userId = null;

if (accessToken && refreshToken) {
  const { data: { user } } = await supabase.auth.setSession({
    access_token: accessToken.value,
    refresh_token: refreshToken.value,
  });
  userId = user?.id;
}

const { data: coursesData } = await supabase
  .from("courses")
  .select(`id, title,
    description, level,
    created_at, 
    lessons (id),
    categories (name)`)
  .eq("is_published", true)
  .order("created_at", { ascending: false });

let completedCoursesIds = new Set();
if (userId && coursesData) {
  const { data: progress } = await supabase
    .from("lesson_progress")
    .select("lesson_id")
    .eq("user_id", userId)
    .eq("completed", true);

  const completedLessonIds = new Set(progress?.map(p => p.lesson_id));
  coursesData.forEach(course => {
    const total = course.lessons?.length || 0;
    if (!total) return;
    const completed = course.lessons.filter(l => completedLessonIds.has(l.id)).length;
    if (completed === total) completedCoursesIds.add(course.id);
  });
}

const workflowSteps = [
    { 
        step: "01", 
        action: t("index.workflow.step1.action"), 
        title: t("index.workflow.step1.title"), 
        desc: t("index.workflow.step1.desc"),
        icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
    },
    { 
        step: "02", 
        action: t("index.workflow.step2.action"), 
        title: t("index.workflow.step2.title"), 
        desc: t("index.workflow.step2.desc"),
        icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
    },
    { 
        step: "03", 
        action: t("index.workflow.step3.action"), 
        title: t("index.workflow.step3.title"), 
        desc: t("index.workflow.step3.desc"),
        icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04M12 2.944l.001-.001.001-.001a11.955 11.955 0 018.618 3.04"
    }
];
---

<Layout title={t("index.title")}>
  <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

  <main class="bg-[#030303] text-white selection:bg-blue-600/50 font-sans antialiased relative overflow-x-hidden">
    
    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_-20%,rgba(37,99,235,0.15),transparent_70%)]"></div>
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('https://grainy-gradients.vercel.app/noise.svg');"></div>
    </div>

    <section class="relative pt-20 md:pt-48 pb-10 md:pb-20 px-4 md:px-6 min-h-screen flex flex-col justify-center z-10 overflow-hidden">
      <div class="max-w-7xl mx-auto text-center relative">
            <div class="inline-flex items-center gap-3 md:gap-4 px-4 py-2 md:px-5 md:py-2.5 rounded-full bg-white/5 border border-white/20 mb-8 md:mb-12 animate-fade-in shadow-lg mx-auto backdrop-blur-sm">
                <span class="w-2 h-2 md:w-2.5 md:h-2.5 rounded-full bg-blue-500 animate-pulse shadow-[0_0_12px_#3b82f6]"></span>
                
                <span class="text-[9px] md:text-[10px] font-extrabold text-blue-500 uppercase tracking-wider md:tracking-wide whitespace-nowrap">
                BRAIN BOX FTC <span class="opacity-40 mx-2">//</span> v2.1.0
                </span>
                
                <span class="text-[9px] md:text-[10px] font-extrabold text-blue-400 uppercase tracking-wider md:tracking-wide whitespace-nowrap">
                By: CANQueens 25668
                </span>
            </div>

            <h1
            class="text-[10vw] sm:text-6xl md:text-[8rem]
                    font-extrabold italic uppercase tracking-wide
                    leading-tight md:leading-[1]
                    text-white drop-shadow-lg
                    mb-6 md:mb-8"
            data-aos="zoom-out"
            >
                <span class="block relative z-10">
                    {t("index.title")}
                </span>

                <span
                    class="block text-transparent opacity-70
                        [-webkit-text-stroke:1px_rgba(255,255,255,0.2)]
                        md:[-webkit-text-stroke:2px_rgba(255,255,255,0.2)]
                        -translate-y-[11vw] sm:-translate-y-16 md:-translate-y-28
                        translate-x-[0.25rem]"
                >
                    {t("index.title")}
                </span>
            </h1>
    
          <div class="max-w-xs sm:max-w-xl mx-auto mb-10 md:mb-16" data-aos="fade-up">
              <p class="text-zinc-500 text-sm md:text-xl leading-relaxed font-light italic px-4">
                  {t("index.subtitle")}
              </p>
          </div>
    
          <div class="flex flex-col sm:flex-row items-center justify-center gap-6 md:gap-8 mb-20 md:mb-32 px-4" data-aos="fade-up" data-aos-delay="200">
              <a href={`/${lang}/register`} class="w-full sm:w-auto group relative px-10 py-4 md:px-12 md:py-5 bg-white text-black font-black uppercase italic tracking-tighter text-xs md:text-sm overflow-hidden transition-transform hover:scale-95 duration-100 text-center">
                  <span class="relative z-10">Deploy System</span>
                  <div class="absolute inset-0 bg-blue-600 translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
              </a>
              <a href="https://github.com/isanchezv07/BRAIN-BOX-FTC" target="_blank" class="text-[10px] font-black uppercase tracking-[0.4em] text-zinc-600 hover:text-blue-500 transition-all py-2">
                  View Source Code <span class="ml-1">_</span>
              </a>
          </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 py-20 md:py-40 relative z-10">
      <div class="mb-24 text-center md:text-left">
          <h2 class="text-blue-600 font-mono text-xs font-bold tracking-[0.4em] uppercase mb-4">{t("index.workflow.label")}</h2>
          <h3 class="text-5xl md:text-6xl font-black italic uppercase tracking-tighter leading-none">
              {t("index.workflow.title").split(" ").slice(0, -1).join(" ")} <span class="text-blue-600">{t("index.workflow.title").split(" ").pop()}</span>
          </h3>
      </div>
  
      <div class="grid grid-cols-1 md:grid-cols-3 gap-16 relative">
          <div class="hidden md:block absolute top-1/2 left-0 w-full h-px bg-gradient-to-r from-blue-600/0 via-blue-600/50 to-blue-600/0 -translate-y-24"></div>
  
          {workflowSteps.map((item, i) => (
              <div class="relative space-y-8 group" data-aos="fade-up" data-aos-delay={i * 200}>
                  <div class="w-16 h-16 rounded-full bg-[#0a0a0a] border-2 border-white/10 flex items-center justify-center text-xl font-black italic text-zinc-500 group-hover:border-blue-600 group-hover:text-blue-600 transition-all duration-500 shadow-[0_0_30px_rgba(0,0,0,1)] z-20 relative">
                      {item.step}
                  </div>
                  <div class="space-y-4">
                      <div class="flex items-center gap-2">
                          <span class="text-[10px] font-black text-blue-500 uppercase tracking-widest">{item.action}</span>
                          <div class="h-px flex-1 bg-white/5"></div>
                      </div>
                      <h4 class="text-4xl font-black italic uppercase tracking-tighter group-hover:text-white transition-colors">{item.title}</h4>
                      <p class="text-zinc-500 text-sm leading-relaxed font-light group-hover:text-zinc-300 transition-colors">{item.desc}</p>
                  </div>
              </div>
          ))}
      </div>
    </section>

    <section id="explore" class="max-w-7xl mx-auto px-6 py-20 md:py-40 z-10 relative">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8 mb-24" data-aos="fade-right">
            <div>
                <h2 class="text-6xl md:text-8xl font-black italic uppercase tracking-tighter mb-4">{t("index.explore.title")}</h2>
                <div class="flex items-center gap-4 text-[10px] font-mono text-zinc-600 uppercase tracking-widest">
                    <span>{t("index.course.status")}</span>
                    <span class="text-blue-600">●</span>
                    <span>Modules: {coursesData?.length || 0}</span>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {coursesData?.slice(-2).map((course, index) => {
            const lessonsCount = course.lessons?.length || 0;
            return (
              <article class="group relative flex flex-col h-full bg-[#080808] border border-white/5 rounded-[2rem] overflow-hidden transition-all duration-500 hover:border-blue-500/40 hover:-translate-y-3 shadow-2xl" data-aos="fade-up" data-aos-delay={index * 50}>
                <div class="absolute inset-x-0 -top-px h-px bg-gradient-to-r from-transparent via-blue-500 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
      
                <a href={`/${lang}/courses/${course.id}`} class="flex flex-col h-full p-8">
                    <div class="flex justify-between items-start mb-8 gap-4">
                        <div class="flex flex-wrap gap-2">
                            <span class="text-[9px] font-black tracking-[0.2em] text-blue-500 bg-blue-500/5 border border-blue-500/10 px-3 py-1 rounded-md uppercase">{course.level}</span>
                            
                            {course.categories?.name && (
                                <div class="relative group/tag">
                                    <div class="absolute inset-0 bg-amber-600/20 blur-md rounded-full opacity-0 group-hover/tag:opacity-100 transition-opacity"></div>
                                    <span class="relative flex items-center gap-2 px-3 py-1 rounded-full border border-amber-500/30 bg-amber-500/10 backdrop-blur-md shadow-[inset_0_0_12px_rgba(245,158,11,0.2)]">
                                        <span class="relative flex h-1.5 w-1.5">
                                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
                                            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-amber-500"></span>
                                        </span>
                                        <span class="text-[8px] font-black uppercase tracking-[0.1em] bg-gradient-to-r from-amber-400 to-yellow-200 bg-clip-text text-transparent italic">{course.categories.name}</span>
                                    </span>
                                </div>
                            )}

                            {completedCoursesIds.has(course.id) && (
                                <div class="flex items-center gap-1.5 px-2 py-1 rounded bg-green-500/5 border border-green-500/10">
                                    <span class="w-1 h-1 rounded-full bg-green-500 animate-pulse"></span>
                                    <span class="text-[7px] font-mono text-green-500 uppercase">Verified</span>
                                </div>
                            )}
                        </div>
                        <span class="text-3xl font-black italic opacity-5 group-hover:opacity-20 transition-all">{String(index + 1).padStart(2, '0')}</span>
                    </div>
      
                    <div class="flex-1">
                        <h3 class="text-3xl font-black italic uppercase tracking-tighter text-white leading-[0.9] mb-4 group-hover:text-blue-400 transition-colors">{course.title}</h3>
                        <p class="text-zinc-500 text-sm font-light leading-relaxed line-clamp-3">{course.description}</p>
                    </div>
      
                    <div class="grid grid-cols-2 gap-4 my-8 py-6 border-y border-white/5">
                        <div class="flex flex-col">
                            <span class="text-[8px] text-zinc-600 font-black uppercase tracking-widest mb-1">Architecture</span>
                            <span class="text-xs font-bold text-zinc-300">v.{new Date(course.created_at).getFullYear()}</span>
                        </div>
                        <div class="flex flex-col border-l border-white/5 pl-4">
                            <span class="text-[8px] text-zinc-600 font-black uppercase tracking-widest mb-1">Modules</span>
                            <span class="text-xs font-bold text-zinc-300">{lessonsCount} {lessonsCount === 1 ? t("index.course.lesson") : t("index.course.lessons")}</span>
                        </div>
                    </div>
      
                    <div class="flex items-center justify-between">
                        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-zinc-500 group-hover:text-white transition-colors">{t("index.course.access")} _</span>
                        <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center bg-white/[0.02] group-hover:bg-blue-600 group-hover:border-blue-600 transition-all duration-500">
                            <svg class="text-white" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </div>
                    </div>
                </a>
                <div class={`absolute bottom-0 left-0 h-1 bg-blue-600 transition-all duration-700 ${completedCoursesIds.has(course.id) ? 'w-full bg-green-500' : 'w-0 group-hover:w-full'}`}></div>
            </article>
            );
          })}
        </div>
    </section>

    <footer class="max-w-7xl mx-auto px-6 py-40 md:py-60 text-center relative z-10">
      <div class="inline-block relative mb-12 group">
          <h2 class="text-5xl md:text-[13rem] font-black italic uppercase tracking-tighter leading-none text-transparent opacity-5 group-hover:opacity-10 [-webkit-text-stroke:1px_white] select-none transition-all duration-700">BUILDCORE</h2>
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
              <h3 class="text-2xl md:text-6xl font-black italic uppercase tracking-tighter text-blue-600 drop-shadow-[0_0_30px_rgba(37,99,235,0.6)] animate-pulse">{t("index.footer.ready")}</h3>
          </div>
      </div>
      <div class="flex justify-center gap-8 md:gap-12 mt-10">
            <a
                href="https://github.com/isanchezv07/BRAIN-BOX-FTC"
                class="text-[9px] md:text-[11px] font-black uppercase tracking-[0.5em] text-zinc-600 hover:text-white transition-all"
                >
                Github
            </a>

            <a
                href="https://www.instagram.com/can.queens25668/"
                class="text-[9px] md:text-[11px] font-black uppercase tracking-[0.5em] text-zinc-600 hover:text-white transition-all"
                >
                Instagram
            </a>
      </div>
    </footer>
  </main>

  <script is:inline src="https://unpkg.com/aos@next/dist/aos.js"></script>
  <script is:inline>
    AOS.init({ offset: 100, duration: 1000, easing: 'ease-out-quart', once: false, mirror: true });
  </script>
</Layout>

<style>
  .stroke-text { -webkit-text-stroke: 1px rgba(255,255,255,0.15); }
  @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  .animate-marquee { animation: marquee 30s linear infinite; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade-in { animation: fadeUp 1s ease forwards; }
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: #030303; }
  ::-webkit-scrollbar-thumb { background: #1a1a1a; }
  ::-webkit-scrollbar-thumb:hover { background: #3b82f6; }
  html { scroll-behavior: smooth; background-color: #030303; }
</style>