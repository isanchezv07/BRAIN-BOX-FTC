---
// @Isanchezv
// src/pages/[locale]/signin.astro
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const error = Astro.url.searchParams.get("error");
---

<Layout title={`${t('auth.signin.button')}`}>
  <main class="min-h-[90vh] flex flex-col items-center justify-center px-6">
    <div class="relative max-w-md w-full p-10 md:p-12 bg-[#0a0a0a] border border-white/5 rounded-[3.5rem] shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-500">
      
      <div class="absolute -top-24 -right-24 w-48 h-48 bg-blue-600/10 blur-[80px] rounded-full pointer-events-none"></div>

      <div class="relative z-10">
        <header class="text-center mb-10">
          <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter leading-none mb-3">
            {t('auth.signin.title')} <span class="text-blue-500 text-glow">{t('auth.signin.titleHighlight')}</span>
          </h1>
          <p class="text-[9px] text-gray-500 uppercase font-black tracking-[0.3em] italic">
            {t('auth.signin.subtitle')}
          </p>
        </header>
        
        {error && (
          <div class="bg-red-500/10 border border-red-500/20 text-red-500 text-[10px] font-black uppercase tracking-widest p-4 rounded-2xl mb-8 text-center animate-shake italic">
            {error}
          </div>
        )}

        <div class="flex gap-2 p-1.5 bg-black border border-white/5 rounded-[1.5rem] mb-8">
          <button id="tab-password" class="flex-1 py-3 text-[9px] font-black uppercase tracking-widest rounded-xl bg-white/5 text-white transition-all shadow-inner">
            STANDARD
          </button>
          <button id="tab-otp" class="flex-1 py-3 text-[9px] font-black uppercase tracking-widest rounded-xl text-gray-600 hover:text-white transition-all">
            MOD OTP
          </button>
        </div>

        <form method="POST" action="/api/auth/signin" data-astro-reload class="space-y-5">
          <input type="hidden" name="lang" value={lang} />
          
          <div class="space-y-2">
            <label class="text-[9px] font-black text-gray-600 uppercase tracking-[0.2em] ml-4">
              {t('auth.signin.labels.email')}
            </label>
            <input 
              name="email" 
              type="email" 
              placeholder={t('auth.signin.placeholders.email')} 
              required 
              class="w-full p-5 rounded-2xl bg-black border border-white/10 text-white outline-none focus:border-blue-500/50 focus:ring-4 focus:ring-blue-500/5 transition-all font-bold text-sm italic" 
            />
          </div>

          <div id="section-password" class="space-y-2 animate-in fade-in slide-in-from-bottom-2 duration-300">
            <div class="flex justify-between items-center px-4">
              <label class="text-[9px] font-black text-gray-600 uppercase tracking-[0.2em]">
                {t('auth.signin.labels.password')}
              </label>
              <a href={`/${lang}/forgot-password`} class="text-[9px] font-black text-blue-500/50 hover:text-blue-500 uppercase tracking-widest transition-colors italic">
                {t('auth.signin.labels.forgot')}
              </a> 
            </div>
            <input 
              id="input-password"
              name="password" 
              type="password" 
              placeholder="••••••••" 
              required
              class="w-full p-5 rounded-2xl bg-black border border-white/10 text-white outline-none focus:border-blue-500/50 transition-all font-bold" 
            />
          </div>

          <div id="section-otp" class="space-y-2 hidden animate-in fade-in slide-in-from-bottom-2 duration-300">
            <label class="text-[9px] font-black text-gray-600 uppercase tracking-[0.2em] ml-4 text-center block">
              {t('auth.signin.labels.otp')}
            </label>
            <input 
              id="input-otp"
              name="otp" 
              type="text" 
              placeholder="000000" 
              maxlength="6"
              class="w-full p-5 rounded-2xl bg-black border border-blue-600/30 text-blue-500 font-black text-center text-2xl tracking-[0.6em] outline-none focus:border-blue-500 transition-all placeholder:text-gray-900" 
            />
            <p class="text-[8px] text-gray-700 text-center uppercase mt-3 tracking-widest leading-relaxed px-4">
              {t('auth.signin.labels.otpNote')}
            </p>
          </div>
          
          <button 
            type="submit" 
            class="group relative w-full py-5 bg-blue-600 text-black font-black uppercase italic rounded-2xl hover:bg-white transition-all active:scale-[0.98] shadow-2xl shadow-blue-900/20 overflow-hidden mt-6 tracking-widest text-xs"
          >
            <span class="relative z-10">{t('auth.signin.button')}</span>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>
          </button>
        </form>

        <p class="mt-8 text-center text-[10px] text-gray-600 uppercase font-black tracking-widest italic">
          New here? <a href={`/${lang}/register`} class="text-blue-500 hover:text-white transition-colors underline underline-offset-4">Join the Academy</a>
        </p>
      </div>
    </div>
  </main>
</Layout>

<script>
  const setupTabs = () => {
    const tabPassword = document.getElementById('tab-password');
    const tabOtp = document.getElementById('tab-otp');
    const sectionPassword = document.getElementById('section-password');
    const sectionOtp = document.getElementById('section-otp');
    const inputPassword = document.getElementById('input-password') as HTMLInputElement;
    const inputOtp = document.getElementById('input-otp') as HTMLInputElement;

    const activateTab = (mode: 'password' | 'otp') => {
      const isPass = mode === 'password';
      
      tabPassword?.classList.toggle('bg-white/5', isPass);
      tabPassword?.classList.toggle('text-white', isPass);
      tabPassword?.classList.toggle('text-gray-600', !isPass);
      
      tabOtp?.classList.toggle('bg-white/5', !isPass);
      tabOtp?.classList.toggle('text-white', !isPass);
      tabOtp?.classList.toggle('text-gray-600', isPass);

      sectionPassword?.classList.toggle('hidden', !isPass);
      sectionOtp?.classList.toggle('hidden', isPass);

      if (inputPassword) {
        inputPassword.required = isPass;
        if (!isPass) inputPassword.value = "";
      }
      if (inputOtp) {
        inputOtp.required = !isPass;
        if (isPass) inputOtp.value = "";
      }
    };

    tabPassword?.addEventListener('click', () => activateTab('password'));
    tabOtp?.addEventListener('click', () => activateTab('otp'));
  };

  setupTabs();
  document.addEventListener('astro:after-swap', setupTabs);
</script>

<style>
  .text-glow { text-shadow: 0 0 15px rgba(37, 99, 235, 0.5); }
  @keyframes shimmer { 100% { transform: translateX(100%); } }
  .animate-shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
  @keyframes shake {
    10%, 90% { transform: translate3d(-1px, 0, 0); }
    20%, 80% { transform: translate3d(2px, 0, 0); }
    30%, 50%, 70% { transform: translate3d(-3px, 0, 0); }
    40%, 60% { transform: translate3d(3px, 0, 0); }
  }
</style>