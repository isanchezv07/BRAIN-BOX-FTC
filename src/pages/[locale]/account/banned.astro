---
// @Isanchezv
// src/pages/[locale]/account/banned.astro
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { locale } = Astro.params;
const reason = Astro.url.searchParams.get("reason") || "Restricción de Seguridad";
const untilRaw = Astro.url.searchParams.get("until");
const until = untilRaw && untilRaw !== "null" ? decodeURIComponent(untilRaw) : null;

const statusMsg = reason === 'temporal' ? t('banned.temp') : t('banned.perm');
---

<Layout title={t('banned.title')}>
  <main class="h-screen w-full bg-[#020202] flex items-center justify-center p-4 font-mono overflow-hidden relative">
    <div class="absolute inset-0 pointer-events-none scanlines"></div>

    <div class="relative w-full max-w-xl animate-in fade-in zoom-in duration-700">
      <div class="bg-black border border-red-900/50 p-8 md:p-12 shadow-[0_0_80px_rgba(153,27,27,0.15)] relative">
        <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-red-600"></div>
        <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-red-600"></div>

        <div class="text-center">
          <h1 class="text-6xl font-black text-red-600 mb-2 glitch-text tracking-tighter">{t('banned.title')}</h1>
          <p class="text-[10px] text-red-900 uppercase tracking-[0.5em] mb-12 font-bold italic">{t('banned.access_revoked')}</p>

          <div class="bg-red-950/10 border-l-4 border-red-600 p-6 mb-10 text-left">
            <span class="text-[10px] font-bold text-red-500 uppercase block mb-1 font-mono">{t('banned.report')}:</span>
            <p class="text-xl text-gray-300 italic font-black uppercase tracking-tight">"{statusMsg}"</p>
          </div>

          <div id="timer-container" class={until ? "block" : "hidden"}>
            <div class="mb-12 bg-white/[0.02] border border-white/5 p-8 rounded-sm">
              <p class="text-[10px] font-bold text-gray-600 uppercase mb-8 italic tracking-[0.2em]">{t('banned.remaining')}</p>
              <div class="flex justify-center items-center gap-4 md:gap-8">
                <div class="flex flex-col">
                    <span id="days" class="text-4xl md:text-5xl text-white font-black">00</span>
                    <span class="text-[8px] text-red-900 uppercase mt-2 font-bold">{t('banned.timer.days')}</span>
                </div>
                <span class="text-2xl text-red-600/20 mb-6">:</span>
                <div class="flex flex-col">
                    <span id="hours" class="text-4xl md:text-5xl text-white font-black">00</span>
                    <span class="text-[8px] text-red-900 uppercase mt-2 font-bold">{t('banned.timer.hours')}</span>
                </div>
                <span class="text-2xl text-red-600/20 mb-6">:</span>
                <div class="flex flex-col">
                    <span id="minutes" class="text-4xl md:text-5xl text-white font-black">00</span>
                    <span class="text-[8px] text-red-900 uppercase mt-2 font-bold">{t('banned.timer.mins')}</span>
                </div>
                <span class="text-2xl text-red-600/20 mb-6">:</span>
                <div class="flex flex-col">
                    <span id="seconds" class="text-4xl md:text-5xl font-black text-red-600 animate-pulse">00</span>
                    <span class="text-[8px] text-red-900 uppercase mt-2 font-bold">{t('banned.timer.secs')}</span>
                </div>
              </div>
            </div>
          </div>

          <a href={`/${locale}/auth/signin`} class="inline-block text-[10px] text-gray-600 hover:text-red-500 transition-all font-bold tracking-[0.3em] uppercase border-b border-transparent hover:border-red-500 pb-1">
            {t('banned.reestablish')}
          </a>
        </div>
      </div>
      
      <div class="mt-6 flex justify-between text-[8px] text-red-900/40 uppercase font-black tracking-widest px-2">
        <span>Node_ID: 0x244-Term</span>
        <span>Secure_Protocol_Active</span>
      </div>
    </div>
  </main>
</Layout>

<style>
  .scanlines {
    background: linear-gradient(to bottom, transparent 50%, rgba(0, 0, 0, 0.4) 51%);
    background-size: 100% 4px;
    z-index: 50;
  }
  .glitch-text {
    text-shadow: 3px 0 #ff0000, -3px 0 #00f0ff;
    animation: glitch 2s infinite;
  }
  @keyframes glitch {
    0% { transform: translate(0) }
    20% { transform: translate(-2px, 2px) }
    40% { transform: translate(-2px, -2px) }
    60% { transform: translate(2px, 2px) }
    80% { transform: translate(2px, -2px) }
    100% { transform: translate(0) }
  }
</style>

<script is:inline define:vars={{ until, locale }}>
  function initTimer() {
    if (!until) return;

    const targetDate = new Date(until).getTime();

    const updateTimer = () => {
      const now = new Date().getTime();
      const distance = targetDate - now;

      if (distance <= 0) {
        window.location.href = `/${locale}/auth/signin`;
        return;
      }

      const d = Math.floor(distance / (1000 * 60 * 60 * 24));
      const h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const s = Math.floor((distance % (1000 * 60)) / 1000);

      const updateEl = (id, val) => {
        const el = document.getElementById(id);
        if (el) el.innerText = val.toString().padStart(2, '0');
      };

      updateEl('days', d);
      updateEl('hours', h);
      updateEl('minutes', m);
      updateEl('seconds', s);
    };

    updateTimer();
    setInterval(updateTimer, 1000);
  }

  document.addEventListener('DOMContentLoaded', initTimer);
  initTimer(); 
</script>