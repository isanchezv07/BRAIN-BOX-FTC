---
// @Isanchezv
// src/pages/[locale]/forgot-password.astro
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const clientConfig = {
  sending: t('forgot.sending'),
  success: t('forgot.success'),
  error_unexpected: t('forgot.error_unexpected'),
  button_original: t('forgot.button')
};
---

<Layout title={`${t('forgot.title')} ${t('forgot.highlight')}`}>
  <section class="flex flex-col items-center justify-center min-h-[70vh] px-6 relative overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-blue-600/5 blur-[120px] rounded-full pointer-events-none"></div>

    <div 
      id="forgot-card"
      data-lang={lang} 
      data-config={JSON.stringify(clientConfig)}
      class="relative w-full max-w-md bg-[#0a0a0a] border border-white/5 p-8 md:p-12 rounded-[3.5rem] shadow-2xl z-10 animate-in fade-in zoom-in duration-500"
    >
      <div class="absolute -top-24 -left-24 w-48 h-48 bg-blue-600/10 blur-[80px] rounded-full pointer-events-none"></div>

      <div class="relative z-10 text-center">
        <h1 class="text-4xl font-black text-white uppercase italic tracking-tighter mb-2 leading-none">
          {t('forgot.title')} <span class="text-blue-500">{t('forgot.highlight')}</span>
        </h1>
        <p class="text-[10px] text-gray-500 uppercase font-black tracking-[0.2em] mb-10 italic">
          {t('forgot.subtitle')}
        </p>

        

        <form id="forgot-password-form" class="space-y-6 text-left">
          <div class="space-y-2">
            <label class="text-[9px] font-black text-gray-600 uppercase tracking-[0.3em] ml-4">{t('forgot.label')}</label>
            <input 
              type="email" 
              id="email-input"
              name="email" 
              required 
              class="w-full p-5 rounded-2xl bg-black border border-white/10 text-white outline-none focus:border-blue-500/50 focus:ring-4 focus:ring-blue-500/5 transition-all placeholder:text-gray-800 italic font-medium"
              placeholder={t('forgot.placeholder')}
            />
          </div>

          <button 
            type="submit" 
            id="submit-btn"
            class="w-full bg-white text-black py-5 rounded-2xl font-black uppercase italic hover:bg-blue-600 hover:text-white transition-all active:scale-[0.98] shadow-xl tracking-widest text-xs"
          >
            {t('forgot.button')}
          </button>
        </form>

        <p id="message" class="mt-8 text-[10px] font-black uppercase tracking-widest min-h-[1.5rem] italic"></p>
      </div>
    </div>
    
    <a href={`/${lang}/signin`} class="mt-8 text-[10px] font-black text-gray-600 hover:text-white uppercase tracking-[0.3em] transition-colors italic">
      ← {t('auth.back_to_login') || 'Back to Login'}
    </a>
  </section>
</Layout>

<script>
  import { supabase } from "@/lib/supabase"; 

  const form = document.getElementById('forgot-password-form') as HTMLFormElement;
  const messageEl = document.getElementById('message');
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const card = document.getElementById('forgot-card');

  const lang = card?.dataset.lang || 'es';
  const config = JSON.parse(card?.dataset.config || '{}');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if (!btn || !messageEl) return;

    btn.disabled = true;
    btn.innerText = config.sending;
    messageEl.textContent = "";

    const emailInput = document.getElementById('email-input') as HTMLInputElement;
    const email = emailInput.value;

    try {
      const { error } = await supabase.auth.resetPasswordForEmail(email, {
        redirectTo: `${window.location.origin}/${lang}/update-password`,
      });

      if (error) {
        messageEl.textContent = error.message;
        messageEl.className = "mt-8 text-[10px] font-black uppercase tracking-widest text-red-500 text-center italic";
        btn.disabled = false;
        btn.innerText = config.button_original;
      } else {
        messageEl.textContent = config.success;
        messageEl.className = "mt-8 text-[10px] font-black uppercase tracking-widest text-green-500 text-center italic animate-pulse";
        form.reset();
        btn.innerText = "✓";
        btn.classList.add('bg-green-500', 'text-white');
      }
    } catch (err) {
      messageEl.textContent = config.error_unexpected;
      btn.disabled = false;
      btn.innerText = config.button_original;
    }
  });
</script>