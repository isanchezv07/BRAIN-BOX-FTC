---
import Layout from "@/layouts/Layout.astro";
import { getFullTeamIntelligence } from "@/lib/ftc";

const { number, locale } = Astro.params;
const intel = await getFullTeamIntelligence(number);

if (!intel.profile) return Astro.redirect('/404');

const getMatchStatus = (match, teamNo) => {
  const teamInMatch = match.teams.find(t => t.teamNumber == teamNo);
  const isRed = teamInMatch?.station.includes('Red');
  
  let win = false;
  if (isRed && match.scoreRedFinal > match.scoreBlueFinal) win = true;
  if (!isRed && match.scoreBlueFinal > match.scoreRedFinal) win = true;
  
  return { win, side: isRed ? 'RED' : 'BLUE' };
};

const getSeasonEventCount = (seasonData) => {
  if (!seasonData?.events) return 0;
  return seasonData.events.length;
};
---

<Layout title={`INTEL // ${intel.profile.nameShort}`}>
  <main class="bg-black text-white min-h-screen p-4 sm:p-8 md:p-20 font-sans relative overflow-x-hidden">
    <div class="fixed inset-0 bg-[radial-gradient(#ffffff05_1px,transparent_1px)] bg-size[20px_20px] pointer-events-none"></div>

    <nav class="mb-12 relative z-10 flex justify-center md:justify-start">
      <a href={`/${locale}/`} class="group text-zinc-600 font-black uppercase text-[10px] tracking-widest hover:text-blue-500 transition-colors flex items-center gap-4">
        <span class="w-8 md:w-10 h-px bg-zinc-800 group-hover:w-16 group-hover:bg-blue-500 transition-all"></span> 
        Back_to_Intel
      </a>
    </nav>

    <header class="mb-20 md:mb-32 relative z-10">
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-16 mb-20 relative z-10">
        <div class="w-full lg:w-auto relative">
          <div class="flex items-center gap-2 mb-4 justify-center md:justify-start">
            <span class="w-2 h-2 bg-blue-500 rounded-full animate-pulse shadow-[0_0_8px_rgba(59,130,246,0.8)]"></span>
          </div>
      
          <h1 class="text-6xl sm:text-8xl md:text-9xl lg:text-[10rem] font-black italic uppercase tracking-tighter leading-[0.8] text-center md:text-left">
            <span class="block text-white drop-shadow-2xl">{intel.profile.nameShort}</span>
            <span class="text-transparent [-webkit-text-stroke:1px_rgba(255,255,255,0.3)]">#{number}</span>
          </h1>
      
          <div class="mt-8 flex justify-center md:justify-start">
            <a 
              href={`/${locale}/alliance/builder-teams?teams=${number}`}
              class="group relative flex items-center gap-4 px-6 py-3 bg-white/3 border border-white/10 rounded-2xl hover:bg-blue-600/10 hover:border-blue-500/50 transition-all duration-500"
            >
              <span class="text-lg group-hover:scale-125 group-hover:rotate-12 transition-transform duration-300">⚔️</span>
              <div class="flex flex-col items-start">
                <span class="text-[9px] font-black uppercase tracking-widest text-zinc-500 group-hover:text-blue-400 transition-colors">Strategic_System</span>
                <span class="text-[11px] font-black uppercase text-white tracking-tighter">Alliance_Builder_v2</span>
              </div>
              <span class="px-4 py-1 rounded-full border border-purple-500/40 bg-purple-500/10 text-purple-400 text-[11px] font-black uppercase tracking-[0.3em] italic shadow-[0_0_15px_rgba(168,85,247,0.15)]">
                Beta
              </span>
            </a>
          </div>
        </div>
      
        <div class="relative w-full lg:max-w-md group">
          <div class="absolute -inset-1 bg-linear-to-r from-blue-600/20 to-transparent blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
          
          <div class="relative bg-zinc-900/40 border-l-4 p-8 md:p-10 rounded-xl md:rounded-r-[2.5rem] backdrop-blur-xl border-y border-r border-white/5 transition-all duration-500 group-hover:border-white/10">
            <div class="flex justify-between items-center mb-6">
              <p class="text-[10px] font-black text-zinc-500 uppercase tracking-[0.3em] italic">Combat_History</p>
              <span class="text-[10px] font-mono text-blue-500/50">SEC_ID: 04-FTC</span>
            </div>
      
            <div class="flex items-baseline justify-between gap-4">
              <div class="flex flex-col">
                <span class="text-5xl md:text-7xl font-black italic text-blue-500 leading-none drop-shadow-[0_0_15px_rgba(59,130,246,0.3)]">
                  {intel.summary.totalWins}W
                </span>
                <span class="text-[9px] font-bold text-zinc-600 uppercase mt-2 tracking-widest">Confirmed_Victories</span>
              </div>
              
              <span class="text-3xl font-black text-zinc-800 italic">/</span>
              
              <div class="flex flex-col items-end text-right">
                <span class="text-5xl md:text-7xl font-black italic text-red-600/80 leading-none group-hover:text-red-600 transition-colors">
                  {intel.summary.totalLosses}L
                </span>
                <span class="text-[9px] font-bold text-zinc-600 uppercase mt-2 tracking-widest">Unit_Failures</span>
              </div>
            </div>
      
            <div class="mt-8 relative">
              <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
                <div 
                  class="h-full bg-linear-to-r from-blue-600 to-blue-400 shadow-[0_0_20px_rgba(37,99,235,0.4)] transition-all duration-1000" 
                  style={`width: ${intel.summary.winRate}%`}
                ></div>
              </div>
              <div class="mt-4 flex justify-between items-center">
                <span class="text-[9px] font-black text-zinc-500 uppercase tracking-widest italic">Efficiency_Matrix:</span>
                <span class="text-2xl font-black italic text-white leading-none">
                  {intel.summary.winRate}<span class="text-xs text-blue-500 ml-0.5">%</span>
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
        <div class="bg-white/5 border border-white/10 p-6 md:p-8 rounded-2xl md:rounded-4xl hover:bg-white/8 transition-colors">
          <p class="text-[10px] font-black uppercase text-zinc-500 mb-2 italic">Career Awards</p>
          <p class="text-4xl md:text-5xl font-black italic text-blue-600">{intel.summary.totalAwards}</p>
        </div>
        <div class="bg-white/5 border border-white/10 p-6 md:p-8 rounded-2xl md:rounded-4xl hover:bg-white/8 transition-colors">
          <p class="text-[10px] font-black uppercase text-zinc-500 mb-2 italic">Peak Score</p>
          <p class="text-4xl md:text-5xl font-black italic text-white">{intel.summary.peakScore}</p>
        </div>
        <div class="hidden lg:block bg-white/5 border border-white/10 p-6 md:p-8 rounded-2xl md:rounded-4xl">
            <p class="text-[10px] font-black uppercase text-zinc-500 mb-2 italic">Rookie Year</p>
            <p class="text-4xl md:text-5xl font-black italic text-zinc-500">{intel.profile.rookieYear}</p>
        </div>
        <div class="bg-blue-600 p-6 md:p-8 rounded-2xl md:rounded-4xl text-black shadow-lg">
          <p class="text-[10px] font-black uppercase opacity-60 mb-2 italic">Location</p>
          <p class="text-lg md:text-2xl font-black italic uppercase leading-tight line-clamp-2">{intel.profile.city}, {intel.profile.country}</p>
        </div>
      </div>
    </header>

    <div class="space-y-24 md:space-y-48 relative z-10">
      {intel.history.map((year) => (
        <section class={year.events.length === 0 ? "opacity-20 pointer-events-none grayscale" : "opacity-100"}>
          <div class="flex flex-col md:flex-row justify-between items-center md:items-end border-b-2 border-white/10 pb-8 mb-12 md:mb-16 gap-6">
            <h2 class="text-7xl sm:text-8xl md:text-9xl font-black italic uppercase tracking-tighter leading-none">{year.season}</h2>
            <div class="flex gap-8 md:gap-12 font-mono uppercase w-full md:w-auto justify-center md:justify-end">
                <div class="flex flex-col items-center md:items-end">
                    <span class="text-zinc-600 text-[8px] md:text-[10px] font-bold tracking-widest">Season_Events</span>
                    <span class="text-white text-4xl md:text-5xl font-black italic">{getSeasonEventCount(year)}</span>
                </div>
                <div class="flex flex-col items-center md:items-end">
                    <span class="text-zinc-600 text-[8px] md:text-[10px] font-bold tracking-widest">Season_Wins</span>
                    <span class="text-blue-500 text-4xl md:text-5xl font-black italic">{year.stats.wins}</span>
                </div>
                <div class="flex flex-col items-center md:items-end border-l border-white/10 pl-8 md:pl-12">
                    <span class="text-zinc-600 text-[8px] md:text-[10px] font-bold tracking-widest">Season_Losses</span>
                    <span class="text-red-600 text-4xl md:text-5xl font-black italic">{year.stats.losses}</span>
                </div>
            </div>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12">
            <div class="lg:col-span-4 order-2 lg:order-1">
              <div class="bg-zinc-900/50 backdrop-blur-md p-6 md:p-10 rounded-4xl md:rounded-[3rem] border border-white/5 sticky top-6">
                <h3 class="text-[10px] font-black uppercase text-blue-500 mb-6 md:mb-8 italic tracking-[0.3em] flex items-center gap-2">
                  <span class="w-2 h-2 bg-blue-500 rounded-full animate-ping"></span> Achievements
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-4">
                  {year.awards.length > 0 ? year.awards.map(a => (
                    <div class="flex gap-4 items-center bg-white/5 p-4 rounded-xl border border-transparent hover:border-blue-500/30 transition-all group">
                      <span class="text-lg group-hover:scale-125 transition-transform">🏆</span>
                      <p class="text-[10px] md:text-[11px] font-bold uppercase italic leading-tight">{a.name}</p>
                    </div>
                  )) : <p class="text-[10px] text-zinc-700 uppercase italic font-black text-center py-8">No_Awards</p>}
                </div>
              </div>
            </div>

            <div class="lg:col-span-8 space-y-8 md:space-y-12 order-1 lg:order-2">
              {year.events.map(event => (
                <div class="bg-white/1 border border-white/5 p-6 md:p-10 rounded-4xl md:rounded-[3rem] hover:bg-white/3 transition-all group duration-500">
                  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 md:mb-10 gap-6">
                    <div class="flex-1 space-y-3">
                      <div class="flex items-center gap-4 flex-wrap">
                        <span class="px-3 py-1 text-[9px] font-black tracking-widest uppercase rounded-md bg-blue-500/10 text-blue-400 border border-blue-500/20">
                          {event.code}
                        </span>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500">
                          {event.city}, {event.country}
                        </span>
                      </div>
                        <h4 class="text-2xl md:text-4xl font-black italic uppercase tracking-tighter leading-tight text-white group-hover:text-blue-400 transition-colors">
                          {event.name}
                        </h4>
                      </div>
                    <a href={`/${locale}/event/${event.code}?team=${number}&season=${year.season}`} 
                       class="w-full md:w-auto text-center bg-white text-black px-6 md:px-8 py-3 md:py-4 rounded-xl md:rounded-2xl font-black italic uppercase text-[10px] md:text-[11px] hover:bg-blue-600 hover:text-white transition-all shadow-xl active:scale-95">
                      View_Report →
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>
  </main>
</Layout>