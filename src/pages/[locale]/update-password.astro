---
// @Isanchezv
// src/pages/[locale]/update-password.astro
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const clientConfig = {
  mismatch: t('update_pass.mismatch'),
  updating: t('update_pass.updating'),
  success: t('update_pass.success'),
  originalBtn: t('update_pass.button')
};
---

<Layout title={`${t('update_pass.title')} ${t('update_pass.highlight')}`}>
  <div class="relative max-w-md mx-auto mt-16 md:mt-24 p-8 md:p-12 bg-[#0a0a0a] border border-white/5 rounded-[3rem] shadow-2xl overflow-hidden">
    
    <div class="absolute -top-24 -right-24 w-48 h-48 bg-blue-600/10 blur-[80px] rounded-full pointer-events-none"></div>

    <div class="relative z-10" id="update-container" data-config={JSON.stringify(clientConfig)} data-lang={lang}>
      <header class="text-center mb-10">
        <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter mb-2 leading-none">
          {t('update_pass.title')} <span class="text-blue-500 text-glow">{t('update_pass.highlight')}</span>
        </h1>
        <p class="text-[10px] text-gray-500 uppercase font-black tracking-[0.2em] italic">{t('update_pass.subtitle')}</p>
      </header>

      <form id="update-form" class="space-y-6">
        <div class="space-y-2">
          <label class="text-[9px] font-black text-gray-600 uppercase tracking-widest ml-4">{t('update_pass.label')}</label>
          <div class="relative group">
            <input 
              id="pass" 
              type="password" 
              required 
              minlength="6" 
              placeholder="••••••••"
              class="w-full p-5 pr-12 rounded-2xl bg-black border border-white/10 text-white outline-none focus:border-blue-500/50 transition-all font-bold" 
            />
            <button type="button" class="toggle-password absolute right-5 top-1/2 -translate-y-1/2 text-gray-700 hover:text-blue-500 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <div class="space-y-2">
          <label class="text-[9px] font-black text-gray-600 uppercase tracking-widest ml-4">{t('update_pass.confirm_label')}</label>
          <div class="relative group">
            <input 
              id="confirm_pass" 
              type="password" 
              required 
              minlength="6" 
              placeholder="••••••••"
              class="w-full p-5 pr-12 rounded-2xl bg-black border border-white/10 text-white outline-none focus:border-blue-500/50 transition-all font-bold" 
            />
            <button type="button" class="toggle-password absolute right-5 top-1/2 -translate-y-1/2 text-gray-700 hover:text-blue-500 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>
        
        <button 
          type="submit" 
          id="submit-btn"
          class="group relative w-full py-5 bg-blue-600 text-black font-black uppercase italic rounded-2xl hover:bg-white transition-all active:scale-[0.98] shadow-2xl shadow-blue-900/10 overflow-hidden mt-6 tracking-widest text-xs"
        >
          <span class="relative z-10" id="btn-text">{t('update_pass.button')}</span>
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>
        </button>

        <p id="msg" class="text-center text-[10px] uppercase font-black tracking-widest mt-8 min-h-[1.5rem] italic"></p>
      </form>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from "@/lib/supabase"; 

  const container = document.getElementById('update-container');
  const form = document.getElementById('update-form') as HTMLFormElement;
  const msg = document.getElementById('msg');
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');
  
  const config = JSON.parse(container?.dataset.config || '{}');
  const lang = container?.dataset.lang || 'es';

  document.querySelectorAll('.toggle-password').forEach(button => {
    button.addEventListener('click', () => {
      const input = button.parentElement?.querySelector('input');
      if (input) {
        const isPassword = input.type === 'password';
        input.type = isPassword ? 'text' : 'password';
        button.classList.toggle('text-blue-500', isPassword);
        button.classList.toggle('text-gray-700', !isPassword);
      }
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const pass = (document.getElementById('pass') as HTMLInputElement).value;
    const confirmPass = (document.getElementById('confirm_pass') as HTMLInputElement).value;

    if (!msg || !btn || !btnText) return;

    if (pass !== confirmPass) {
      msg.innerText = config.mismatch;
      msg.className = "text-red-500 text-center text-[10px] font-black uppercase tracking-widest mt-8 animate-shake italic";
      return;
    }

    btn.disabled = true;
    btnText.innerText = config.updating;
    msg.innerText = "";

    const { error } = await supabase.auth.updateUser({ password: pass });

    if (error) {
      msg.innerText = error.message;
      msg.className = "text-red-500 text-center text-[10px] font-black uppercase tracking-widest mt-8 italic";
      btn.disabled = false;
      btnText.innerText = config.originalBtn;
    } else {
      msg.innerText = config.success;
      msg.className = "text-green-500 text-center text-[10px] font-black uppercase tracking-widest mt-8 italic animate-pulse";
      
      await supabase.auth.signOut();
      
      setTimeout(() => window.location.assign(`/${lang}/signin`), 2500);
    }
  });
</script>

<style>
  .text-glow { text-shadow: 0 0 20px rgba(37, 99, 235, 0.4); }
  @keyframes shimmer { 100% { transform: translateX(100%); } }
  .animate-shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
  @keyframes shake {
    10%, 90% { transform: translate3d(-1px, 0, 0); }
    20%, 80% { transform: translate3d(2px, 0, 0); }
    30%, 50%, 70% { transform: translate3d(-3px, 0, 0); }
    40%, 60% { transform: translate3d(3px, 0, 0); }
  }
</style>