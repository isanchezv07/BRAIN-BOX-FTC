---
// @Isanchezv
// src/pages/[locale]/login-emergency.astro
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const clientConfig = {
  syncMsg: t('emergency.sync'),
  invalidMsg: t('emergency.errors.invalid'),
  loadingMsg: t('emergency.btn.loading'),
  defaultBtn: t('emergency.btn.default'),
  lang: lang
};
---

<Layout title={`${t('emergency.title')}`}>
  <main 
    class="min-h-screen bg-[#050505] flex items-center justify-center px-4 relative overflow-hidden"
    x-data={`{ 
        username: '', 
        otp: '', 
        loading: false, 
        error: '',
        success: false,
        config: ${JSON.stringify(clientConfig)}
    }`}
  >
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,_rgba(147,51,234,0.07),_transparent)]"></div>

    <div class="max-w-md w-full bg-[#0a0a0a] border border-white/5 p-10 rounded-[3.5rem] shadow-2xl relative z-10 overflow-hidden">
      
      <div x-show="success" x-transition.opacity class="absolute inset-0 bg-purple-600 flex flex-col items-center justify-center z-[100] text-white text-center p-8">
        <div class="w-20 h-20 bg-white/20 rounded-[2rem] flex items-center justify-center mb-6 animate-pulse">
          <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h2 class="text-3xl font-black uppercase italic tracking-tighter">{t('emergency.bypass')}</h2>
        <p class="text-white/80 text-[10px] font-black uppercase tracking-[0.3em] mt-4" x-text="config.syncMsg"></p>
      </div>

      <div class="text-center mb-10">
        <div class="inline-block px-3 py-1 border border-purple-500/30 rounded-full mb-4">
            <span class="text-[8px] font-black text-purple-500 uppercase tracking-[0.4em] animate-pulse">System_Bypass_Active</span>
        </div>
        <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter leading-none">
          {t('emergency.title')} <span class="text-purple-600">{t('emergency.highlight')}</span>
        </h1>
      </div>

      <form @submit.prevent="
        loading = true;
        error = '';
        try {
            const res = await fetch('/api/auth/verify-otp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, otp })
            });
            
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || config.invalidMsg);

            // Auth real con el cliente de Supabase
            const { error: loginError } = await window.supabase.auth.signInWithPassword({
                email: data.email,
                password: data.password
            });
            if (loginError) throw loginError;

            // ACTIVAR SALVOCONDUCTO
            document.cookie = 'emergency_access_active=true; path=/; max-age=60; SameSite=Lax; Secure';

            success = true;
            setTimeout(() => {
                window.location.href = '/' + config.lang + '/dashboard';
            }, 1800);
        } catch (e) {
            error = e.message;
            loading = false;
        }
      " class="space-y-5">
        
        <div class="space-y-1">
            <label class="text-[9px] font-black text-gray-600 uppercase tracking-widest ml-4">{t('emergency.placeholders.user')}</label>
            <input 
                type="text" 
                x-model="username" 
                required
                class="w-full bg-black border border-white/10 rounded-2xl px-6 py-4 text-white font-bold outline-none focus:border-purple-500 transition-all uppercase text-xs tracking-widest"
                placeholder="---"
            />
        </div>

        <div class="space-y-1">
            <label class="text-[9px] font-black text-gray-600 uppercase tracking-widest ml-4 text-center block w-full">{t('emergency.placeholders.otp')}</label>
            <input 
                type="text" 
                x-model="otp" 
                maxlength="6"
                required
                class="w-full bg-black border border-white/10 rounded-2xl px-6 py-5 text-center text-3xl font-black text-purple-500 outline-none focus:border-purple-600 transition-all tracking-[0.3em]"
                placeholder="000000"
            />
        </div>

        <template x-if="error">
            <div class="bg-red-500/5 border border-red-500/20 p-4 rounded-2xl animate-in fade-in slide-in-from-top-2">
                <p class="text-red-500 text-[10px] font-black text-center uppercase tracking-widest" x-text="error"></p>
            </div>
        </template>

        <button 
          type="submit" 
          :disabled="loading"
          class="w-full py-5 bg-purple-600 hover:bg-purple-500 disabled:opacity-50 disabled:cursor-not-allowed text-white font-black rounded-2xl uppercase text-[11px] tracking-[0.3em] transition-all shadow-[0_0_30px_rgba(147,51,234,0.2)]"
        >
          <span x-text="loading ? config.loadingMsg : config.defaultBtn"></span>
        </button>
      </form>
      
      <p class="text-center mt-8 text-[8px] text-gray-700 font-black uppercase tracking-[0.4em]">Secure Terminal Connection</p>
    </div>
  </main>
</Layout>

<script>
  import { supabase } from "@/lib/supabase";
  // @ts-ignore
  window.supabase = supabase;
</script>