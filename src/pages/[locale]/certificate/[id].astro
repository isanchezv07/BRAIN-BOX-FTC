---
// @Isanchezv
// src/pages/[locale]/certificate/[id].astro
import Layout from "@/layouts/Layout.astro";
import { getSupabaseAdmin } from "@/lib/supabase"; 
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import CertificateGenerator from "@/components/CertificateGenerator.astro";

const { id: courseId } = Astro.params;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");

if (!accessToken || !refreshToken) return Astro.redirect(`/${lang}/auth/signin`);

const supabaseAdmin = getSupabaseAdmin();
const { data: { user: authUser } } = await supabaseAdmin.auth.setSession({
  access_token: accessToken.value,
  refresh_token: refreshToken.value,
});

if (!authUser) return Astro.redirect(`/${lang}/auth/signin`);

const { data: course } = await supabaseAdmin.from("courses").select("id, title").eq("id", courseId).single();
if (!course) return Astro.redirect(`/${lang}/account/dashboard`);

const { data: profile } = await supabaseAdmin.from("profiles").select("full_name").eq("id", authUser.id).single();
const userName = profile?.full_name?.trim() || authUser.email || t('congrats.defaultUser');
---

<Layout title={`${t('congrats.actionWord')}! - ${course.title}`}>
  <main class="min-h-screen bg-[#060606] flex flex-col items-center justify-center px-6 overflow-hidden relative pb-32">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,_rgba(234,179,8,0.08),_transparent)]"></div>

    <div class="max-w-4xl w-full text-center z-10">
      <header class="mb-6 animate-bounce">
        <div class="inline-block p-4 rounded-full bg-yellow-500/10 mb-4">
            <span class="text-6xl">✨</span>
        </div>
      </header>

      <h1 class="text-6xl md:text-8xl font-black text-white italic uppercase tracking-tighter mb-4 leading-none">
        {t('congrats.tagline').split('{action}')[0]}
        <span class="text-yellow-500">{t('congrats.actionWord')}</span>
        {t('congrats.tagline').split('{action}')[1]}
      </h1>
      
      <p class="text-gray-400 text-lg font-medium mb-12">
        {t('congrats.awardedTo')} <span class="text-white font-bold">{userName}</span>
      </p>

      <div class="relative z-50 my-12 min-h-[400px]">
          <CertificateGenerator 
            userName={userName} 
            courseTitle={course.title} 
            courseId={course.id}
            userId={authUser.id}
          />
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-20 relative z-50">
        <a href={`/${lang}/account/dashboard`} class="group px-8 py-4 bg-white text-black font-bold uppercase italic rounded-full hover:bg-yellow-400 transition-all flex items-center gap-2">
          {t('congrats.buttons.dashboard')}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <button id="celebrate-btn" class="px-8 py-4 bg-white/5 border border-white/10 text-white font-bold uppercase italic rounded-full hover:bg-white/10 transition-all">
          {t('congrats.buttons.celebrate')}
        </button>
      </div>
    </div>
    <canvas id="congrats-canvas" class="absolute inset-0 pointer-events-none z-0"></canvas>
  </main>
</Layout>

<script>
  import confetti from 'canvas-confetti';
  const launch = () => { confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 }, colors: ['#eab308', '#ffffff', '#22c55e'] }); };
  document.addEventListener('astro:page-load', () => {
    setTimeout(launch, 300);
    document.getElementById('celebrate-btn')?.addEventListener('click', launch);
  });
</script>