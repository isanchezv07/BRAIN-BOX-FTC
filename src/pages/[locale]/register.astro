---
// @Isanchezv
// src/pages/[locale]/register.astro
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const errorParam = Astro.url.searchParams.get("error");
---

<Layout title={`${t('auth.register.title')}`}>
  <main class="min-h-[90vh] flex flex-col items-center justify-center px-6">
    <div class="max-w-md w-full p-10 bg-[#0a0a0a] border border-white/5 rounded-[2.5rem] shadow-2xl animate-in fade-in zoom-in duration-500">
      
      <div class="text-center mb-10">
        <h1 class="text-4xl font-black text-white italic uppercase tracking-tighter leading-none">
          {t('auth.register.title')}
        </h1>
      </div>
      
      {errorParam && (
        <div class="bg-red-500/10 border border-red-500/20 text-red-500 text-[10px] font-bold uppercase tracking-widest p-4 rounded-2xl mb-8 text-center animate-shake">
          {errorParam}
        </div>
      )}

      <form id="register-form" method="POST" action="/api/auth/register" class="space-y-4">
        <input type="hidden" name="lang" value={lang} />

        <div class="space-y-1">
          <input type="text" name="full_name" placeholder={t('auth.register.placeholders.username')} required class="w-full p-5 rounded-2xl bg-black border border-white/10 text-white outline-none focus:border-blue-500 text-sm font-bold transition-all" />
          <p class="text-[9px] text-blue-400/60 italic px-4 leading-tight">
            {t('auth.register.helpers.certNote')}
          </p>
        </div>

        <input type="text" name="username" placeholder={t('auth.register.placeholders.fullName')} required class="w-full p-5 rounded-2xl bg-black border border-white/10 text-white outline-none focus:border-blue-500 text-sm font-bold transition-all" />
        
        <input type="email" name="email" placeholder={t('auth.register.placeholders.email')} required class="w-full p-5 rounded-2xl bg-black border border-white/10 text-white outline-none focus:border-blue-500 text-sm font-bold transition-all" />
        
        <div class="relative">
          <input 
            id="password"
            type="password" 
            name="password" 
            placeholder={t('auth.register.placeholders.password')} 
            required 
            class="w-full p-5 rounded-2xl bg-black border border-white/10 text-white outline-none focus:border-blue-500 text-sm font-bold transition-all" 
          />
          <button type="button" class="toggle-password absolute right-5 top-1/2 -translate-y-1/2 text-gray-700 hover:text-blue-500 transition-colors" data-target="password">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          </button>
        </div>

        <p id="length-helper" class="text-[9px] font-black text-gray-700 uppercase tracking-widest pl-4 transition-colors">
          {t('auth.register.helpers.passwordLength')}
        </p>

        <div class="relative">
          <input 
            id="confirmPassword"
            type="password" 
            placeholder={t('auth.register.placeholders.confirmPassword')} 
            required 
            class="w-full p-5 rounded-2xl bg-black border border-white/10 text-white outline-none focus:border-blue-500 text-sm font-bold transition-all" 
          />
          <button type="button" class="toggle-password absolute right-5 top-1/2 -translate-y-1/2 text-gray-700 hover:text-blue-500 transition-colors" data-target="confirmPassword">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          </button>
        </div>
        
        <p id="password-error" class="hidden text-[9px] font-black text-red-500 uppercase tracking-widest text-center italic">
          {t('auth.register.helpers.passwordMismatch')}
        </p>

        <button type="submit" class="w-full py-5 bg-blue-600 text-black font-black uppercase italic rounded-2xl hover:bg-white transition-all active:scale-95 shadow-xl shadow-blue-600/10 tracking-widest text-xs">
          {t('auth.register.button')}
        </button>
      </form>

      <p class="mt-8 text-center text-[10px] text-gray-600 uppercase font-black tracking-widest">
        {t('auth.register.hasAccount')} <a href={`/${lang}/signin`} class="text-blue-500 hover:text-white transition-colors underline underline-offset-4">{t('auth.register.loginLink')}</a>
      </p>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const confirmInput = document.getElementById('confirmPassword') as HTMLInputElement;
  const lengthHelper = document.getElementById('length-helper');
  const errorMsg = document.getElementById('password-error');
  const toggleButtons = document.querySelectorAll('.toggle-password');

  toggleButtons.forEach(button => {
    button.addEventListener('click', () => {
      const targetId = button.getAttribute('data-target');
      const input = document.getElementById(targetId) as HTMLInputElement;
      input.type = input.type === 'password' ? 'text' : 'password';
      button.classList.toggle('text-blue-500');
    });
  });

  passwordInput?.addEventListener('input', () => {
    const isValid = passwordInput.value.length >= 6;
    lengthHelper?.classList.toggle('text-green-500', isValid);
    lengthHelper?.classList.toggle('text-gray-700', !isValid);
  });

  form?.addEventListener('submit', (e) => {
    let hasError = false;
    
    if (passwordInput.value.length < 6) {
      hasError = true;
      lengthHelper?.classList.add('text-red-500');
    }

    if (passwordInput.value !== confirmInput.value) {
      hasError = true;
      errorMsg?.classList.remove('hidden');
      confirmInput.classList.add('border-red-500');
    }

    if (hasError) e.preventDefault();
  });
</script>