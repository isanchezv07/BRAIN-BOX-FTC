---
// @Isanchezv
// src/pages/auth/callback.astro
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Email Verificado">
  <div class="relative min-h-screen flex items-center justify-center bg-[#0a0a0a] overflow-hidden">
    
    <div class="relative z-10 text-center">
      <div id="success-icon" class="relative inline-block mb-8 opacity-0 translate-y-4 transition-all duration-700">
        <div class="absolute inset-0 bg-green-500/10 blur-2xl rounded-full animate-pulse"></div>
        
        <div class="relative w-24 h-24 flex items-center justify-center border-2 border-green-500/20 rounded-full bg-white/[0.02] backdrop-blur-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-green-500 drop-shadow-[0_0_8px_rgba(34,197,94,0.4)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
      </div>

      <div id="text-container" class="space-y-3 opacity-0 translate-y-4 transition-all duration-700 delay-150">
        <h1 class="text-white font-black italic uppercase tracking-tighter text-3xl">
          Email <span class="text-green-500">Verificado</span>
        </h1>
        
        <div class="flex items-center justify-center gap-3">
          <span class="h-[1px] w-6 bg-white/5"></span>
          <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-gray-500 italic">
            Redirigiendo a tu academia
          </p>
          <span class="h-[1px] w-6 bg-white/5"></span>
        </div>
      </div>

      <div class="mt-10 w-48 mx-auto h-[1px] bg-white/5 rounded-full overflow-hidden">
        <div id="progress-bar" class="h-full bg-green-500 w-0 transition-all duration-[1500ms] ease-out"></div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from "@/lib/supabase";

  const handleAuth = async () => {
    document.getElementById('success-icon')?.classList.remove('opacity-0', 'translate-y-4');
    document.getElementById('text-container')?.classList.remove('opacity-0', 'translate-y-4');
    
    setTimeout(() => {
      const bar = document.getElementById('progress-bar');
      if (bar) bar.style.width = '100%';
    }, 100);

    const { data, error } = await supabase.auth.getSession();

    if (error || !data.session) {
      setTimeout(() => {
        window.location.href = "/es/signin?error=session_expired";
      }, 1000);
      return;
    }

    const { access_token, refresh_token, user } = data.session;
    const cookieOptions = "; path=/; SameSite=Lax; Secure";
    const maxAge = `; max-age=${60 * 60 * 24 * 7}`;

    document.cookie = `sb-access-token=${access_token}${cookieOptions}${maxAge}`;
    document.cookie = `sb-refresh-token=${refresh_token}${cookieOptions}${maxAge}`;
    document.cookie = `emergency_access_active=true${cookieOptions}; max-age=60`;
    
    const tempName = user.user_metadata?.full_name || user.user_metadata?.username || user.email?.split('@')[0];
    document.cookie = `temp_username=${encodeURIComponent(tempName)}${cookieOptions}; max-age=60`;

    setTimeout(() => {
      window.location.href = "/es/dashboard";
    }, 2000);
  };

  window.addEventListener("load", handleAuth);
</script>

<style>
  svg {
    animation: checkBounce 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes checkBounce {
    0% { transform: scale(0) rotate(-45deg); opacity: 0; }
    100% { transform: scale(1) rotate(0); opacity: 1; }
  }
</style>