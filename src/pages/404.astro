---
// @Isanchezv
// src/pages/404.astro
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import DataCatcher from "@/components/DataCatcher.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const usefulLinks = [
  { href: `/${lang}/dashboard`, text: t('errors.404.links.dashboard') },
  { href: `/${lang}/courses`, text: t('errors.404.links.courses') },
];
---

<Layout title={t('errors.404.title')}>
  <main class="relative min-h-screen w-full flex flex-col items-center justify-center bg-[#080808] overflow-hidden font-mono text-blue-500">
    
    <div class="absolute inset-0 z-0 pointer-events-none">
      <div class="w-full h-[2px] bg-blue-500/20 shadow-[0_0_20px_rgba(59,130,246,0.5)] absolute animate-scan"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(59,130,246,0.05)_0%,transparent_70%)]"></div>
    </div>

    <div class="relative z-10 select-none">
      <h1 class="text-[25vw] md:text-[30vw] font-black leading-none tracking-tighter text-transparent stroke-text opacity-20">
        404
      </h1>
      <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4">
        <h2 class="text-4xl md:text-7xl font-black text-white uppercase tracking-[0.2em] mb-4 drop-shadow-[0_0_15px_rgba(255,255,255,0.5)]">
            {t('errors.404.title')}
        </h2>
        
        <div class="bg-blue-950/30 backdrop-blur-sm border-x-2 border-blue-500 px-6 py-3">
          <p class="typewriter-text text-sm md:text-2xl font-bold uppercase tracking-widest text-blue-400">
            {t('errors.404.description')}
          </p>
        </div>
        <div class="hidden md:block">
          <DataCatcher t={t} lang={lang} />
        </div>
      </div>
    </div>

    <footer class="relative z-20 mt-16 w-full max-w-5xl px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-10 border-t border-blue-500/20 pt-10">
        
        <div class="flex-shrink-0">
          <a href={`/${lang}/`} 
             class="group relative inline-block px-10 py-4 bg-blue-600 text-black font-black uppercase text-[11px] tracking-[0.3em] transition-all duration-300 hover:bg-white hover:-translate-y-1 active:translate-y-0">
            {t('errors.404.button')}
            <span class="absolute -bottom-1.5 -right-1.5 w-full h-full border-b border-r border-blue-400/50 group-hover:border-white transition-all"></span>
          </a>
        </div>
    
        <nav class="flex flex-wrap items-center justify-center md:justify-end gap-x-8 gap-y-3">
          {usefulLinks.map((link, index) => (
            <div class="flex items-center gap-4">
              <a href={link.href} 
                 class="text-[10px] font-bold text-blue-400/40 hover:text-white uppercase tracking-[0.25em] transition-all duration-300">
                {link.text}
              </a>
              {index !== usefulLinks.length - 1 && (
                <span class="w-1 h-1 bg-blue-900 rotate-45 hidden sm:block"></span>
              )}
            </div>
          ))}
        </nav>
      </div>
    
      <div class="mt-8 flex justify-between items-center text-[8px] text-blue-900 uppercase tracking-[0.5em] font-bold">
        <span>{t('errors.404.system_status')}</span>
        <span class="animate-pulse">{t('errors.404.waiting')}</span>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .stroke-text {
    -webkit-text-stroke: 2px rgba(59, 130, 246, 0.5);
  }

  @keyframes scan {
    0% { top: -10%; }
    100% { top: 110%; }
  }
  .animate-scan {
    animation: scan 4s linear infinite;
  }

  .typewriter-text {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    border-right: 4px solid #3b82f6;
    width: 0;
    animation: 
      typing 2s steps(30, end) forwards,
      blink-caret 0.8s step-end infinite;
    animation-delay: 0.5s;
  }

  @keyframes typing {
    from { width: 0 }
    to { width: 100% }
  }

  @keyframes blink-caret {
    from, to { border-color: transparent }
    50% { border-color: #3b82f6 }
  }

  @media (max-width: 768px) {
    .typewriter-text {
      white-space: normal;
      width: auto;
      border-right: none;
      animation: fade-in 1s ease-out forwards;
    }
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>